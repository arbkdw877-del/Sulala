function openAddPair(){ editingId=null; openPairModal(null); }
function openEditPair(id){ editingId=id; openPairModal(DB.breeding.find(p=>p.id===id)); }

function openPairModal(p){
  document.getElementById('modal-title-text').textContent = p?'✏️ تعديل الزوج':'💑 إضافة زوج جديد';
  const males = DB.birds.filter(b=>b.gender==='male'&&b.status!=='dead');
  const females = DB.birds.filter(b=>b.gender==='female'&&b.status!=='dead');
  document.getElementById('modal-body').innerHTML=`
  <div class="form-grid">
    <div class="fg"><label>الأب 🔵</label><select id="fp-male"><option value="">— اختر ذكر —</option>${males.map(b=>`<option value="${b.id}"${p?.maleId===b.id?' selected':''}>${esc(b.name||'ذكر')}</option>`).join('')}</select></div>
    <div class="fg"><label>الأم 🔴</label><select id="fp-female"><option value="">— اختر أنثى —</option>${females.map(b=>`<option value="${b.id}"${p?.femaleId===b.id?' selected':''}>${esc(b.name||'أنثى')}</option>`).join('')}</select></div>
    <div class="fg"><label>رقم القفص</label><input id="fp-cage" placeholder="مثال: A-1" value="${esc(p?.cage||'')}"></div>
    <div class="fg"><label>تاريخ الجمع</label><input id="fp-date" type="date" value="${p?.pairedDate||today()}"></div>
    <div class="form-divider">معلومات البيض</div>
    <div class="fg"><label>تاريخ وضع البيض</label><input id="fp-eggdate" type="date" onchange="onFpEggChange()" value="${p?.eggDate||''}"></div>
    <div class="fg"><label>عدد البيض</label><input id="fp-eggcount" type="number" min="0" placeholder="0" value="${p?.eggCount||''}"></div>
    <div class="fg"><label>أيام الحضانة</label><input id="fp-hdays" type="number" value="${p?.hatchDays||21}" onchange="onFpEggChange()"></div>
    <div class="fg"><label>الفقس المتوقع</label><input id="fp-exphatch" type="date" value="${p?.expectedHatch||''}"></div>
    <div class="fg full"><label>ملاحظات</label><textarea id="fp-notes">${esc(p?.notes||'')}</textarea></div>
  </div>
  <div class="flex-row" style="margin-top:14px;gap:8px">
    <button class="btn btn-primary" style="flex:1;justify-content:center;padding:12px" onclick="savePair()">✓ حفظ</button>
    <button class="btn btn-secondary" style="flex:1;justify-content:center;padding:12px" onclick="closeModal()">إلغاء</button>
  </div>`;
  openModal();
}

function onFpEggChange(){
  const ed = document.getElementById('fp-eggdate')?.value;
  const hd = parseInt(document.getElementById('fp-hdays')?.value)||21;
  if(ed){ const expH=addDays(ed,hd); document.getElementById('fp-exphatch').value=expH; }
}

function savePair(){
  const maleId = document.getElementById('fp-male')?.value;
  const femaleId = document.getElementById('fp-female')?.value;
  if(!maleId||!femaleId){ showToast('⚠️ اختر الأب والأم','warn'); return; }
  const pair = {
    maleId,femaleId,cage:document.getElementById('fp-cage')?.value?.trim(),
    pairedDate:document.getElementById('fp-date')?.value||today(),
    eggDate:document.getElementById('fp-eggdate')?.value,eggCount:document.getElementById('fp-eggcount')?.value,
    hatchDays:document.getElementById('fp-hdays')?.value||21,expectedHatch:document.getElementById('fp-exphatch')?.value,
    notes:document.getElementById('fp-notes')?.value?.trim(),
  };
  if(editingId){ DB.breeding=DB.breeding.map(p=>p.id===editingId?{...p,...pair}:p); showToast('✅ تم التحديث'); }
  else{ pair.id=uid(); pair.createdAt=today(); DB.breeding.push(pair); showToast('✅ تم إضافة الزوج'); }
  saveDB(); closeModal(); refreshCurrent();
}


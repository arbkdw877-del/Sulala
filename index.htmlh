// MODALS — FINANCE
// ══════════════════════════════════
function openAddExpense(){
  document.getElementById('modal-title-text').textContent='➕ إضافة مصروف';
  document.getElementById('modal-body').innerHTML=`
  <div class="form-grid">
    <div class="fg"><label>الفئة</label><select id="fe-cat">${EXP_CATS.map(c=>`<option value="${c}">${c}</option>`).join('')}</select></div>
    <div class="fg"><label>المبلغ (${DB.settings.currency})</label><input id="fe-amount" type="number" min="0" placeholder="0"></div>
    <div class="fg"><label>التاريخ</label><input id="fe-date" type="date" value="${today()}"></div>
    <div class="fg full"><label>الملاحظات</label><input id="fe-notes" placeholder="تفاصيل المصروف"></div>
  </div>
  <button class="btn btn-primary btn-block" style="margin-top:14px" onclick="saveExpense()">✓ إضافة</button>`;
  openModal();
}

function saveExpense(){
  const amount = Number(document.getElementById('fe-amount')?.value)||0;
  if(!amount){ showToast('⚠️ أدخل المبلغ','warn'); return; }
  DB.expenses.push({id:uid(),category:document.getElementById('fe-cat')?.value,amount,date:document.getElementById('fe-date')?.value||today(),notes:document.getElementById('fe-notes')?.value?.trim()});
  saveDB(); closeModal(); finTab='expenses'; refreshCurrent(); showToast('✅ تم إضافة المصروف');
}

function openAddSale(){
  document.getElementById('modal-title-text').textContent='💸 تسجيل بيعة';
  const availBirds = DB.birds.filter(b=>b.status!=='dead');
  document.getElementById('modal-body').innerHTML=`
  <div class="form-grid">
    <div class="fg full"><label>الطير (اختياري)</label><select id="fs-bird"><option value="">— طير خارج النظام —</option>${availBirds.map(b=>`<option value="${b.id}">${esc(b.name||'طير')} (${b.type||'—'})</option>`).join('')}</select></div>
    <div class="fg"><label>اسم المشتري</label><input id="fs-buyer" placeholder="الاسم"></div>
    <div class="fg"><label>المبلغ (${DB.settings.currency})</label><input id="fs-amount" type="number" min="0" placeholder="0"></div>
    <div class="fg"><label>التاريخ</label><input id="fs-date" type="date" value="${today()}"></div>
    <div class="fg full"><label>ملاحظات</label><input id="fs-notes" placeholder="أي تفاصيل"></div>
  </div>
  <button class="btn btn-primary btn-block" style="margin-top:14px" onclick="saveSale()">✓ تسجيل البيعة</button>`;
  openModal();
}

function saveSale(){
  const amount = Number(document.getElementById('fs-amount')?.value)||0;
  if(!amount){ showToast('⚠️ أدخل المبلغ','warn'); return; }
  const birdId = document.getElementById('fs-bird')?.value;
  const buyer = document.getElementById('fs-buyer')?.value?.trim();
  const birdName = birdId ? (DB.birds.find(b=>b.id===birdId)?.name||'طير') : document.getElementById('fs-notes')?.value||'طير';
  DB.sales.push({id:uid(),birdId,birdName,buyer,amount,date:document.getElementById('fs-date')?.value||today(),notes:document.getElementById('fs-notes')?.value?.trim()});
  if(birdId){DB.birds=DB.birds.map(b=>b.id===birdId?{...b,status:'sold',buyer}:b);}
  saveDB(); closeModal(); finTab='sales'; refreshCurrent(); showToast('✅ تم تسجيل البيعة');
}


<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="theme-color" content="#07100a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="مزرعتي">
<link rel="apple-touch-icon" href="https://emojicdn.elk.sh/🦜?style=apple">
<title>🦜 مزرعة طيوري Pro</title>
<style>
:root{
  --g:#4ade80;--gd:#16a34a;--gdr:#052e16;
  --bg:#07100a;--bg2:#0c1a0e;--bg3:#10201200;--card:#0c1a0e;
  --brd:#1a341f;--brd2:#254d2a;
  --txt:#ecfdf5;--txt2:#6b9a72;--txt3:#2d4d30;
  --red:#f87171;--yel:#fbbf24;--ora:#fb923c;--blu:#60a5fa;--pur:#c084fc;--pink:#f472b6;
  --nav-h:64px;--hdr-h:56px;--radius:16px;
  --font:'Noto Kufi Arabic',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;font-family:var(--font);background:var(--bg);color:var(--txt);direction:rtl}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:2px}
select option{background:#0c1a0e}
input[type=date],input[type=number],input[type=time]{color-scheme:dark}

/* ── SPLASH SCREEN ── */
#splash{
  position:fixed;inset:0;z-index:9999;
  background:radial-gradient(ellipse at 50% 60%, #0e2a12 0%, #07100a 70%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;
  transition:opacity .6s ease, transform .6s ease;
}
#splash.hide{opacity:0;transform:scale(1.04);pointer-events:none}

.splash-glow{
  position:absolute;
  width:320px;height:320px;
  border-radius:50%;
  background:radial-gradient(circle, #4ade8022 0%, transparent 70%);
  animation:splash-pulse 2.5s ease-in-out infinite;
}
@keyframes splash-pulse{
  0%,100%{transform:scale(1);opacity:.6}
  50%{transform:scale(1.15);opacity:1}
}

.splash-icon{
  font-size:82px;
  margin-bottom:18px;
  animation:splash-float 3s ease-in-out infinite;
  position:relative;z-index:1;
  filter:drop-shadow(0 0 24px #4ade8077);
}
@keyframes splash-float{
  0%,100%{transform:translateY(0px)}
  50%{transform:translateY(-8px)}
}

.splash-app-name{
  font-size:36px;font-weight:900;
  background:linear-gradient(135deg,#4ade80,#86efac,#4ade80);
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:splash-shimmer 2s linear infinite;
  position:relative;z-index:1;
  letter-spacing:2px;
}
@keyframes splash-shimmer{
  0%{background-position:0% center}
  100%{background-position:200% center}
}

.splash-tagline{
  font-size:13px;color:#6b9a72;margin-top:6px;
  letter-spacing:1px;font-weight:600;
  position:relative;z-index:1;
}

.splash-divider{
  width:60px;height:2px;
  background:linear-gradient(90deg,transparent,#4ade8066,transparent);
  margin:20px 0 16px;
  border-radius:2px;
  position:relative;z-index:1;
}

.splash-sub{
  font-size:11px;color:#2d4d30;
  letter-spacing:.8px;text-transform:uppercase;font-weight:700;
  position:relative;z-index:1;
}

.splash-loader{
  position:absolute;bottom:60px;
  display:flex;gap:7px;align-items:center;
}
.splash-dot{
  width:7px;height:7px;border-radius:50%;
  background:#4ade80;
  animation:splash-dots .8s ease-in-out infinite;
}
.splash-dot:nth-child(1){animation-delay:0s}
.splash-dot:nth-child(2){animation-delay:.15s;background:#86efac}
.splash-dot:nth-child(3){animation-delay:.3s;background:#bbf7d0}
@keyframes splash-dots{
  0%,80%,100%{transform:scale(.5);opacity:.3}
  40%{transform:scale(1);opacity:1}
}

.splash-version{
  position:absolute;bottom:26px;
  font-size:10px;color:#1a341f;
  font-weight:600;letter-spacing:.5px;
}

/* ── APP SHELL ── */
#app{display:flex;flex-direction:column;height:100%;height:100dvh}
#app-header{display:flex;align-items:center;justify-content:space-between;padding:0 16px;height:var(--hdr-h);background:var(--bg2);border-bottom:1px solid var(--brd);flex-shrink:0;gap:8px}
#app-header h1{font-size:18px;font-weight:900;color:var(--g);white-space:nowrap}
.hdr-btns{display:flex;gap:6px;align-items:center}
#app-main{flex:1;overflow:hidden;position:relative}
.page{position:absolute;inset:0;overflow-y:auto;padding:14px 14px calc(var(--nav-h) + 14px);display:none}
.page.active{display:block}
#bottom-nav{height:var(--nav-h);background:var(--bg2);border-top:1px solid var(--brd);display:flex;flex-shrink:0;position:relative;z-index:10;direction:ltr}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;background:none;border:none;color:var(--txt3);cursor:pointer;font-family:var(--font);transition:color .15s;padding:6px 2px}
.nav-btn .ni{font-size:22px;line-height:1}
.nav-btn .nl{font-size:9px;font-weight:600}
.nav-btn.active{color:var(--g)}

/* ── BUTTONS ── */
.btn{font-family:var(--font);border:none;border-radius:12px;cursor:pointer;font-weight:700;transition:all .15s;display:inline-flex;align-items:center;gap:5px;justify-content:center}
.btn-primary{background:linear-gradient(135deg,var(--gd),var(--g));color:#000;padding:11px 18px;font-size:14px}
.btn-primary:active{opacity:.85}
.btn-secondary{background:var(--bg2);border:1px solid var(--brd2);color:var(--txt2);padding:9px 14px;font-size:13px}
.btn-secondary:active{background:var(--brd)}
.btn-sm{padding:6px 10px;font-size:12px;border-radius:9px}
.btn-danger{background:#3a0a0a;border:1px solid var(--red)44;color:var(--red)}
.btn-warn{background:#2a1500;border:1px solid var(--yel)44;color:var(--yel)}
.btn-info{background:#0a1a30;border:1px solid var(--blu)44;color:var(--blu)}
.btn-pur{background:#1a0a2a;border:1px solid var(--pur)44;color:var(--pur)}
.btn-block{width:100%;justify-content:center;padding:13px}

/* ── CARDS ── */
.card{background:var(--card);border:1px solid var(--brd);border-radius:var(--radius);padding:14px}
.card-sm{padding:10px 12px}
.section-title{font-size:11px;font-weight:800;color:var(--txt3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.section-title::after{content:'';flex:1;height:1px;background:var(--brd)}

/* ── STATS ROW ── */
.stats-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:8px;margin-bottom:14px}
.stat-card{background:var(--card);border:1px solid var(--brd);border-radius:14px;padding:12px 8px;text-align:center;cursor:default}
.stat-card .se{font-size:20px;margin-bottom:2px}
.stat-card .sv{font-size:22px;font-weight:900;line-height:1}
.stat-card .sl{font-size:10px;color:var(--txt3);margin-top:2px}

/* ── ALERTS ── */
.alert-card{border-radius:14px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:center;gap:10px}
.alert-card.red{background:#250505;border:1px solid var(--red)66;animation:pls-r 1.5s ease-in-out infinite}
.alert-card.yel{background:#1c1000;border:1px solid var(--yel)55;animation:pls-y 2s ease-in-out infinite}
.alert-card.blu{background:#050a20;border:1px solid var(--blu)44}
@keyframes pls-r{0%,100%{box-shadow:0 0 0 rgba(248,113,113,0)}50%{box-shadow:0 0 16px rgba(248,113,113,.25)}}
@keyframes pls-y{0%,100%{border-color:var(--yel)55}50%{border-color:var(--yel)cc}}
.alert-icon{font-size:28px;flex-shrink:0}
.alert-body h3{font-size:14px;font-weight:700;margin-bottom:2px}
.alert-body p{font-size:12px;color:var(--txt2)}
.alert-actions{margin-right:auto;display:flex;gap:5px;flex-shrink:0}

/* ── BIRD CARD ── */
.bird-card{border-radius:var(--radius);padding:14px;position:relative;background:var(--card);border:1px solid var(--brd);margin-bottom:10px;transition:border-color .15s}
.bird-card.hatch-today{border-color:var(--red)88}
.bird-card.hatch-soon{border-color:var(--yel)55}
.bc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.bc-name{font-size:17px;font-weight:800}
.bc-sub{font-size:11px;color:var(--g);margin-top:1px}
.bc-actions{display:flex;gap:4px}
.bc-badges{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px}
.badge{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:700;border:1px solid}
.bc-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.ib{background:var(--bg);border-radius:9px;padding:7px 9px}
.ib .ibl{font-size:9px;color:var(--txt3);margin-bottom:1px}
.ib .ibv{font-size:12px;font-weight:700}
.hatch-bar{margin:8px 0}
.hb-label{display:flex;justify-content:space-between;font-size:10px;color:var(--txt2);margin-bottom:4px}
.hb-track{height:5px;background:var(--brd);border-radius:3px;overflow:hidden}
.hb-fill{height:100%;border-radius:3px;transition:width .5s}
.bc-notes{background:var(--bg);border-radius:8px;padding:7px 9px;font-size:11px;color:var(--txt2);border-right:2px solid var(--brd2);margin-top:8px}
.bc-quickbtns{display:flex;gap:5px;margin-top:8px;flex-wrap:wrap}

/* ── FINANCE ── */
.fin-summary{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px}
.fin-card{border-radius:14px;padding:14px 10px;text-align:center;border:1px solid}
.fin-card .fv{font-size:20px;font-weight:900;margin-top:4px}
.fin-card .fl{font-size:11px;margin-top:2px}
.transaction-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card);border-radius:12px;margin-bottom:7px;border:1px solid var(--brd)}
.ti-icon{font-size:22px;flex-shrink:0}
.ti-body{flex:1}
.ti-body .tib-title{font-size:13px;font-weight:700}
.ti-body .tib-sub{font-size:11px;color:var(--txt2)}
.ti-amount{font-size:15px;font-weight:800;white-space:nowrap}
.chart-container{background:var(--card);border:1px solid var(--brd);border-radius:var(--radius);padding:14px;margin-bottom:14px}
.chart-container canvas{width:100%!important;max-height:180px}

/* ── BREEDING ── */
.pair-card{border-radius:var(--radius);padding:14px;background:var(--card);border:1px solid var(--brd);margin-bottom:10px}
.pair-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.pair-birds{display:flex;align-items:center;gap:8px;font-weight:700;font-size:14px}
.pair-separator{color:var(--pur);font-size:18px}
.chick-stage{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700}

/* ── HEALTH ── */
.health-record{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;background:var(--card);border-radius:12px;margin-bottom:7px;border:1px solid var(--brd)}
.hr-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:3px}
.reminder-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card);border-radius:12px;margin-bottom:7px;border:1px solid var(--brd)}
.ri-icon{font-size:20px;flex-shrink:0}
.ri-body{flex:1}
.ri-body .rib-title{font-size:13px;font-weight:700}
.ri-body .rib-sub{font-size:11px;color:var(--txt2)}
.ri-actions{display:flex;gap:4px}

/* ── GENES ── */
.gene-result{background:var(--card);border:1px solid var(--brd);border-radius:var(--radius);padding:14px;margin-top:14px}
.gene-result-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--brd)}
.gene-result-row:last-child{border:none}
.gene-color-dot{width:16px;height:16px;border-radius:50%;flex-shrink:0;border:1px solid rgba(255,255,255,.2)}
.gene-pct-bar{height:6px;background:var(--brd);border-radius:3px;flex:1;margin:0 10px;overflow:hidden}
.gene-pct-fill{height:100%;border-radius:3px;background:var(--g)}

/* ── MODAL ── */
#modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(6px);display:flex;align-items:flex-end;justify-content:center;z-index:100;opacity:0;pointer-events:none;transition:opacity .2s}
#modal-overlay.open{opacity:1;pointer-events:all}
#modal{background:#0c1f0e;border:1px solid var(--brd2);border-radius:22px 22px 0 0;padding:20px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;transform:translateY(40px);transition:transform .25s}
#modal-overlay.open #modal{transform:translateY(0)}
.modal-drag{width:40px;height:4px;background:var(--brd2);border-radius:2px;margin:0 auto 16px}
.modal-title{font-size:18px;font-weight:800;color:var(--g);margin-bottom:18px;display:flex;justify-content:space-between;align-items:center}
.modal-close-btn{background:none;border:none;color:var(--txt3);font-size:24px;cursor:pointer;padding:0;line-height:1}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fg{display:flex;flex-direction:column;gap:5px}
.fg.full{grid-column:1/-1}
.fg label{font-size:10px;font-weight:800;color:var(--g);text-transform:uppercase;letter-spacing:.5px}
.fg input,.fg select,.fg textarea{background:#091509;border:1px solid var(--brd2);border-radius:9px;color:var(--txt);padding:9px 11px;font-size:13px;outline:none;font-family:var(--font);width:100%}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--g)}
.fg textarea{min-height:65px;resize:vertical}
.form-divider{grid-column:1/-1;border-top:1px solid var(--brd);padding-top:8px;margin-top:2px;font-size:10px;font-weight:800;color:var(--txt3);text-transform:uppercase;letter-spacing:.5px}
.hatch-preview-box{grid-column:1/-1;background:#0a2510;border:1px solid var(--g)44;border-radius:10px;padding:10px 13px;font-size:13px;color:var(--g)}

/* ── CONFIRM ── */
#confirm-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .15s;padding:16px}
#confirm-overlay.open{opacity:1;pointer-events:all}
#confirm-box{background:#150505;border:1px solid var(--red)55;border-radius:20px;padding:26px;text-align:center;max-width:320px;width:100%}
#confirm-box .ci{font-size:44px;margin-bottom:12px}
#confirm-box h3{color:var(--red);margin-bottom:6px;font-size:17px}
#confirm-box p{color:var(--txt2);font-size:12px;margin-bottom:18px}
#confirm-box .cb{display:flex;gap:8px}
#confirm-box .cb button{flex:1}

/* ── TOAST ── */
#toast-wrap{position:fixed;top:calc(var(--hdr-h) + 8px);left:50%;transform:translateX(-50%);z-index:300;display:flex;flex-direction:column;gap:6px;align-items:center;pointer-events:none;width:90vw}
.toast{background:#0d2a0d;border:1px solid var(--g)88;border-radius:12px;padding:10px 16px;font-size:13px;font-weight:600;text-align:center;animation:t-in .25s ease;pointer-events:all;max-width:340px}
.toast.err{background:#2a0505;border-color:var(--red)88}
.toast.warn{background:#1c1000;border-color:var(--yel)88}
@keyframes t-in{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}

/* ── EMPTY STATE ── */
.empty-state{text-align:center;padding:50px 20px}
.empty-state .es-icon{font-size:54px;margin-bottom:12px}
.empty-state p{color:var(--txt3);font-size:14px;margin-bottom:16px}

/* ── TABS (in-page) ── */
.tab-row{display:flex;gap:6px;margin-bottom:14px;overflow-x:auto;padding-bottom:2px}
.tab-btn{background:var(--bg2);border:1px solid var(--brd);border-radius:10px;color:var(--txt2);padding:7px 14px;font-size:12px;font-family:var(--font);cursor:pointer;font-weight:600;white-space:nowrap;transition:all .15s}
.tab-btn.active{background:var(--gd);border-color:var(--g);color:#000}

/* ── QR ── */
#qr-display img{border-radius:12px;background:white;padding:8px}

/* ── MISC ── */
.flex-row{display:flex;align-items:center;gap:8px}
.flex-row-sb{display:flex;align-items:center;justify-content:space-between;gap:8px}
.gap-2{gap:8px}
.mt{margin-top:10px}
.mb{margin-bottom:10px}
.w100{width:100%}
.text-red{color:var(--red)}
.text-yel{color:var(--yel)}
.text-g{color:var(--g)}
.text-pur{color:var(--pur)}
.text-blu{color:var(--blu)}

@media(min-width:600px){
  .form-grid{grid-template-columns:1fr 1fr}
  #modal{border-radius:22px;margin-bottom:20px;align-self:center}
  #modal-overlay{align-items:center}
}
</style>
</head>
<body>
<!-- ══ SPLASH SCREEN ══ -->
<div id="splash">
  <div class="splash-glow"></div>
  <div class="splash-icon">🦜</div>
  <div class="splash-app-name">سلالة</div>
  <div class="splash-divider"></div>
  <div class="splash-sub">إدارة ذكية لمزرعتك</div>
  <div class="splash-loader">
    <div class="splash-dot"></div>
    <div class="splash-dot"></div>
    <div class="splash-dot"></div>
  </div>
  <div class="splash-version">v7.0 Pro</div>
</div>

<div id="app">
  <header id="app-header">
    <h1 id="hdr-title">🦜 مزرعتي</h1>
    <div class="hdr-btns" id="hdr-btns"></div>
  </header>
  <main id="app-main">
    <div class="page active" id="page-home"></div>
    <div class="page" id="page-birds"></div>
    <div class="page" id="page-finance"></div>
    <div class="page" id="page-breeding"></div>
    <div class="page" id="page-health"></div>
    <div class="page" id="page-genes"></div>
    <div class="page" id="page-settings"></div>
  </main>
  <nav id="bottom-nav">
    <button class="nav-btn" data-page="settings" onclick="showPage('settings')"><span class="ni">⚙️</span><span class="nl">الإعدادات</span></button>
    <button class="nav-btn" data-page="genes" onclick="showPage('genes')"><span class="ni">🧬</span><span class="nl">الجينات</span></button>
    <button class="nav-btn" data-page="health" onclick="showPage('health')"><span class="ni">❤️</span><span class="nl">الصحة</span></button>
    <button class="nav-btn" data-page="breeding" onclick="showPage('breeding')"><span class="ni">🥚</span><span class="nl">التكاثر</span></button>
    <button class="nav-btn" data-page="finance" onclick="showPage('finance')"><span class="ni">💰</span><span class="nl">المالية</span></button>
    <button class="nav-btn" data-page="birds" onclick="showPage('birds')"><span class="ni">🦜</span><span class="nl">طيوري</span></button>
    <button class="nav-btn active" data-page="home" onclick="showPage('home')"><span class="ni">🏠</span><span class="nl">الرئيسية</span></button>
  </nav>
</div>

<div id="modal-overlay" onclick="handleMOverlay(event)">
  <div id="modal">
    <div class="modal-drag"></div>
    <div class="modal-title"><span id="modal-title-text">إضافة</span><button class="modal-close-btn" onclick="closeModal()">×</button></div>
    <div id="modal-body"></div>
  </div>
</div>

<div id="confirm-overlay">
  <div id="confirm-box">
    <div class="ci" id="ci-icon">🗑️</div>
    <h3 id="ci-title">هل أنت متأكد؟</h3>
    <p id="ci-msg">لا يمكن التراجع عن هذا الإجراء.</p>
    <div class="cb">
      <button class="btn btn-danger" id="ci-yes">تأكيد</button>
      <button class="btn btn-secondary" onclick="closeConfirm()">إلغاء</button>
    </div>
  </div>
</div>

<div id="toast-wrap"></div>
<input type="file" id="import-file" accept=".json" style="display:none" onchange="handleImport(event)">

<script>
// ══════════════════════════════════
// CONFIG
// ══════════════════════════════════
const VER = 'bird-pro-v1';
const HATCH_DAYS = {
  'كاسكو':28,'نيبالي':26,'هندي':23,
  'أفريقي':28,'كنيور':26,'كويكر':19,
  'ماكاو':26,'أمازوني':26,'كوكيتيل':21,
  'فيشر':23,'روز':23,'زيبرا':12,
  'كناري':14,'بلبل عراقي':14,'بادجي':18
};
const MARKET_PRICES = {
  'درة': {
    emoji: '🦜', label: 'الدرة الهندي',
    items: [
      {name:'أخضر عادي',         min:350000, max:600000,  notes:'اللون الطبيعي الأصلي'},

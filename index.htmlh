let finTab = 'summary', brdTab = 'pairs', hlthTab = 'records';

// ══════════════════════════════════
// STORAGE
// ══════════════════════════════════
function loadDB(){try{const r=localStorage.getItem(VER);if(r)DB=Object.assign(DB,JSON.parse(r))}catch(e){}}
function saveDB(){try{localStorage.setItem(VER,JSON.stringify(DB))}catch(e){}}

// ══════════════════════════════════
// UTILS
// ══════════════════════════════════
const today = () => new Date().toISOString().split('T')[0];
const now = () => new Date().toISOString();
const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2,6);
const esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const addDays = (d,n) => { const dt=new Date(d); dt.setDate(dt.getDate()+n); return dt.toISOString().split('T')[0]; };
const daysDiff = (a,b) => Math.round((new Date(b)-new Date(a))/86400000);
const fmtDate = s => s ? new Date(s).toLocaleDateString('ar-SA',{day:'numeric',month:'long',year:'numeric'}) : '—';
const fmtMoney = n => (Number(n)||0).toLocaleString('ar-SA');
const getHatchDays = t => HATCH_DAYS[t]||21;

function exactAge(bd){
  if(!bd) return '—';
  const diff = daysDiff(bd, today());
  if(diff<0) return '—';
  if(diff===0) return 'وُلد اليوم 🎂';
  if(diff<7) return diff+' يوم';
  if(diff<30) return Math.floor(diff/7)+' أسبوع';
  const m=Math.floor(diff/30.44);
  if(m<12){const rem=diff-Math.floor(m*30.44);return m+' شهر'+(rem>0?' و'+rem+' يوم':'');}
  const y=Math.floor(diff/365.25), rm=Math.floor((diff-y*365.25)/30.44);
  return y+' سنة'+(rm>0?' و'+rm+' شهر':'');
}

// ══════════════════════════════════
// NAVIGATION
// ══════════════════════════════════
const PAGE_TITLES = {home:'🏠 الرئيسية',birds:'🦜 طيوري',finance:'💰 المالية',breeding:'🥚 التكاثر',health:'❤️ الصحة',genes:'🧬 حاسبة الجينات',settings:'⚙️ الإعدادات'};
const PAGE_HDRS = {
  home: () => `<button class="btn btn-primary btn-sm" onclick="openAddBird()">+ طير</button>`,
  birds: () => `<button class="btn btn-primary btn-sm" onclick="openAddBird()">+ إضافة</button>`,
  finance: () => `<button class="btn btn-primary btn-sm" onclick="openAddExpense()">+ مصروف</button>`,
  breeding: () => `<button class="btn btn-primary btn-sm" onclick="openAddPair()">+ زوج</button>`,
  health: () => `<button class="btn btn-primary btn-sm" onclick="openAddHealth()">+ سجل</button>`,
  genes: () => '',
  settings: () => '',
};

function showPage(id){
  currentPage = id;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.toggle('active', b.dataset.page===id));
  document.getElementById('hdr-title').textContent = PAGE_TITLES[id]||'🦜 مزرعتي';
  document.getElementById('hdr-btns').innerHTML = (PAGE_HDRS[id]||(() => ''))();
  renderPage(id);
  if(id === 'settings'){
    setTimeout(() => updateCurrencyBadge(DB.settings.currency || 'IQD'), 80);
  }
}

function renderPage(id){
  const el = document.getElementById('page-'+id);
  switch(id){
    case 'home':     el.innerHTML = renderHome(); break;
    case 'birds':    el.innerHTML = renderBirds(); break;
    case 'finance':  el.innerHTML = renderFinance(); break;
    case 'breeding': el.innerHTML = renderBreeding(); break;
    case 'health':   el.innerHTML = renderHealth(); break;
    case 'genes':    el.innerHTML = renderGenes(); break;
    case 'settings': el.innerHTML = renderSettings(); break;
  }
}

function refreshCurrent(){ renderPage(currentPage); }

// ══════════════════════════════════
// HOME PAGE
// ══════════════════════════════════
function renderHome(){
  const tod = today();
  const in7 = addDays(tod, 7);
  const todayHatchers = DB.birds.filter(b=>b.status==='eggs'&&b.expectedHatch===tod);
  const soonHatchers = DB.birds.filter(b=>b.status==='eggs'&&b.expectedHatch>tod&&b.expectedHatch<=in7);
  const dueReminders = DB.reminders.filter(r=>r.nextDate<=tod&&!r.done);
  const avail = DB.birds.filter(b=>b.status==='available');
  const soldVal = DB.sales.reduce((s,x)=>s+(Number(x.amount)||0),0);
  const expVal = DB.expenses.reduce((s,x)=>s+(Number(x.amount)||0),0);
  const profit = soldVal - expVal;

  let alerts = '';
  todayHatchers.forEach(b=>{
    alerts += `<div class="alert-card red"><div class="alert-icon">🚨</div><div class="alert-body"><h3 class="text-red">فقس اليوم: ${esc(b.name)}</h3><p>${b.type||''} • ${b.eggCount||'?'} بيضة</p></div><div class="alert-actions"><button class="btn btn-warn btn-sm" onclick="quickHatch('${b.id}')">🐣 سجّل</button></div></div>`;
  });
  soonHatchers.forEach(b=>{
    const diff = daysDiff(tod, b.expectedHatch);
    alerts += `<div class="alert-card yel"><div class="alert-icon">⏳</div><div class="alert-body"><h3 class="text-yel">${esc(b.name)} — بعد ${diff} يوم</h3><p>الفقس المتوقع: ${fmtDate(b.expectedHatch)}</p></div></div>`;
  });
  dueReminders.forEach(r=>{
    alerts += `<div class="alert-card blu"><div class="alert-icon">${r.icon||'🔔'}</div><div class="alert-body"><h3 class="text-blu">${esc(r.title)}</h3><p>${r.type}</p></div><div class="alert-actions"><button class="btn btn-secondary btn-sm" onclick="doneReminder('${r.id}')">✓ تم</button></div></div>`;
  });

  return `
  ${alerts}
  <div class="stats-row">
    <div class="stat-card"><div class="se">🦜</div><div class="sv text-g">${DB.birds.filter(b=>b.status!=='dead').length}</div><div class="sl">الطيور</div></div>
    <div class="stat-card"><div class="se">🟢</div><div class="sv text-g">${avail.length}</div><div class="sl">متوفر</div></div>
    <div class="stat-card"><div class="se">🥚</div><div class="sv text-yel">${DB.birds.filter(b=>b.status==='eggs').length}</div><div class="sl">البيض</div></div>
    <div class="stat-card"><div class="se">📈</div><div class="sv" style="color:${profit>=0?'#4ade80':'#f87171'};font-size:16px">${fmtMoney(profit)}</div><div class="sl">صافي ربح</div></div>
    <div class="stat-card"><div class="se">💰</div><div class="sv text-yel" style="font-size:16px">${fmtMoney(avail.reduce((s,b)=>s+(Number(b.price)||0),0))}</div><div class="sl">قيمة المتوفر</div></div>
    <div class="stat-card"><div class="se">🔴</div><div class="sv text-red">${DB.birds.filter(b=>b.status==='sold').length}</div><div class="sl">مُباع</div></div>
  </div>
  <div class="card mb" style="border-color:var(--brd2)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div style="font-size:15px;font-weight:800;color:var(--g)">📈 بورصة السوق اليوم</div>
      <button class="btn btn-secondary btn-sm" onclick="loadMarketPrices()">🔄 تحديث</button>
    </div>
    <div id="market-list-container">
      <div style="text-align:center;padding:16px;font-size:12px;color:var(--txt3)">اضغط تحديث لعرض أسعار الطيور بعملتك</div>
    </div>
  </div>
  <div class="section-title">آخر الطيور المضافة</div>
  ${DB.birds.slice(-3).reverse().map(b=>renderBirdCard(b,true)).join('')||'<div class="empty-state"><div class="es-icon">🦜</div><p>لا يوجد طيور بعد</p><button class="btn btn-primary" onclick="openAddBird();showPage(\'birds\')">+ أضف أول طير</button></div>'}
  `;
}

// ══════════════════════════════════
// BIRDS PAGE
// ══════════════════════════════════
function renderBirds(){
  const filtered = getFilteredBirds();
  return `
  <div style="display:flex;gap:8px;margin-bottom:10px">
    <input style="flex:1;background:#0c1a0e;border:1px solid var(--brd);border-radius:10px;color:var(--txt);padding:9px 12px;font-size:13px;outline:none;font-family:var(--font)" placeholder="🔍 بحث..." oninput="birdSearch=this.value;refreshCurrent()" value="${esc(birdSearch)}">
    <select style="background:#0c1a0e;border:1px solid var(--brd);border-radius:10px;color:var(--txt2);padding:9px;font-family:var(--font);font-size:12px;outline:none" onchange="birdSort=this.value;refreshCurrent()">
      <option value="name" ${birdSort==='name'?'selected':''}>الاسم</option>
      <option value="age_asc" ${birdSort==='age_asc'?'selected':''}>الأصغر</option>
      <option value="age_desc" ${birdSort==='age_desc'?'selected':''}>الأكبر</option>
      <option value="price_desc" ${birdSort==='price_desc'?'selected':''}>الأعلى سعراً</option>
      <option value="hatch" ${birdSort==='hatch'?'selected':''}>موعد الفقس</option>
      <option value="status" ${birdSort==='status'?'selected':''}>الحالة</option>
    </select>
  </div>
  <div class="tab-row">
    ${['all:🦜 الكل','available:🟢 متوفر','sold:🔴 مُباع','eggs:🥚 البيض','hatched:🐣 فقست','tame:💚 أليف','wild:⚡ مو أليف','dead:🪦 نافق'].map(x=>{
      const[v,l]=x.split(':'); return `<button class="tab-btn${birdFilter===v?' active':''}" onclick="birdFilter='${v}';refreshCurrent()">${l}</button>`;
    }).join('')}
  </div>
  ${filtered.length===0?`<div class="empty-state"><div class="es-icon">🦜</div><p>لا توجد نتائج</p></div>`:filtered.map(b=>renderBirdCard(b)).join('')}
  `;
}

function getFilteredBirds(){
  let list = [...DB.birds];
  if(birdSearch){const q=birdSearch.toLowerCase();list=list.filter(b=>(b.name||'').toLowerCase().includes(q)||(b.type||'').toLowerCase().includes(q)||(b.color||'').toLowerCase().includes(q));}
  if(birdFilter==='tame') list=list.filter(b=>b.tame==='tame'&&b.status!=='dead');
  else if(birdFilter==='wild') list=list.filter(b=>b.tame==='wild'&&b.status!=='dead');
  else if(birdFilter!=='all') list=list.filter(b=>b.status===birdFilter);
  list.sort((a,b_)=>{
    if(birdSort==='name') return (a.name||'').localeCompare(b_.name||'','ar');
    if(birdSort==='age_asc') return (a.birthDate||'9')<(b_.birthDate||'9')?1:-1;
    if(birdSort==='age_desc') return (a.birthDate||'0')>(b_.birthDate||'0')?1:-1;
    if(birdSort==='price_desc') return (Number(b_.price)||0)-(Number(a.price)||0);
    if(birdSort==='hatch'){return (a.expectedHatch||'9999').localeCompare(b_.expectedHatch||'9999');}
    if(birdSort==='status') return (STATUS_ORDER[a.status]||0)-(STATUS_ORDER[b_.status]||0);
    return 0;
  });
  return list;
}

function renderBirdCard(b, compact=false){
  const sc = STATUS_CFG[b.status]||STATUS_CFG.available;
  const tc = TAME_CFG[b.tame]||TAME_CFG.wild;
  const gc = GENDER_CFG[b.gender]||GENDER_CFG.unknown;
  const age = exactAge(b.birthDate);
  const tod = today();
  const isToday = b.status==='eggs'&&b.expectedHatch===tod;
  const isSoon = b.status==='eggs'&&b.expectedHatch>tod&&daysDiff(tod,b.expectedHatch)<=5;

  let hatchHtml='';
  if(b.status==='eggs'&&b.expectedHatch){
    const diff=daysDiff(tod,b.expectedHatch);
    const hdays=getHatchDays(b.type);
    const pct=b.eggDate?Math.min(100,Math.round((daysDiff(b.eggDate,tod)/hdays)*100)):null;
    const col=diff<=0?'#f87171':diff<=3?'#fbbf24':'#4ade80';
    const lab=diff<0?`تأخر ${Math.abs(diff)} يوم!`:diff===0?'🚨 اليوم!':diff+' يوم متبقي';
    hatchHtml=`<div class="hatch-bar"><div class="hb-label"><span>🥚 الحضانة (${hdays}ي)</span><span style="color:${col};font-weight:700">${lab}</span></div>${pct!==null?`<div class="hb-track"><div class="hb-fill" style="width:${pct}%;background:${col}"></div></div>`:''}</div>`;
  }

  const buyerRow = b.status==='sold'&&b.buyer?`<div class="ib full" style="grid-column:1/-1"><div class="ibl">المشتري</div><div class="ibv">${esc(b.buyer)}</div></div>`:'';
  const eggRow = (b.status==='eggs'||b.status==='hatched')&&b.eggCount?`<div class="ib"><div class="ibl">البيض/الفقس</div><div class="ibv">${b.eggCount}🥚${b.hatchCount?' /'+b.hatchCount+'🐣':''}</div></div>`:'';
  const earningRow = b.purchasePrice&&b.price?(() => {const gain=Number(b.price)-Number(b.purchasePrice);return `<div class="ib"><div class="ibl">الربح المتوقع</div><div class="ibv" style="color:${gain>=0?'#4ade80':'#f87171'}">${gain>=0?'+':''}${fmtMoney(gain)}</div></div>`;})():'';

  let quickBtns='';
  if(!compact){
    if(b.status==='eggs') quickBtns+=`<button class="btn btn-warn btn-sm" onclick="quickHatch('${b.id}')">🐣 سجّل الفقس</button>`;
    if(b.status==='available') quickBtns+=`<button class="btn btn-info btn-sm" onclick="quickSell('${b.id}')">💸 بيع</button>`;
    if(['available','hatched'].includes(b.status)) quickBtns+=`<button class="btn btn-secondary btn-sm" onclick="quickEggs('${b.id}')">🥚 البيض</button>`;
    quickBtns+=`<button class="btn btn-pur btn-sm" onclick="showQR('${b.id}')">📱 QR</button>`;
    const mpKey = {'الدرة الهندي':'درة','درة':'درة','الكناري':'كناري','كناري':'كناري','الكنيور':'كنيور','كنيور':'كنيور','الكويكر':'كويكر','كويكر':'كويكر','الكوكتيل':'كوكتيل','كوكتيل':'كوكتيل','كوكيتيل':'كوكتيل','فيشر':'فيشر','روز':'روز','كاسكو':'كاسكو','هندي':'هندي','نيبالي':'هندي','أفريقي':'أفريقي','ماكاو':'ماكاو','أمازوني':'أمازوني','بادجي':'بادجي','زيبرا':'زيبرا','بلبل عراقي':'بلبل'}[b.type];
    if(mpKey&&MARKET_PRICES[mpKey]) quickBtns+=`<button class="btn btn-secondary btn-sm" onclick="showMarketPrice('${mpKey}')">📊 سعر السوق</button>`;
  }

  return `
  <div class="bird-card${isToday?' hatch-today':isSoon?' hatch-soon':''}" id="bc-${b.id}">
    <div class="bc-top">
      <div>
        <div class="bc-name">${gc.emoji} ${esc(b.name||'بدون اسم')}</div>
        <div class="bc-sub">${esc(b.type||'')}${b.color?' • '+esc(b.color):''}</div>
      </div>
      <div class="bc-actions">
        <button class="btn btn-secondary btn-sm" onclick="openEditBird('${b.id}')">✏️</button>
        <button class="btn btn-danger btn-sm" onclick="askDelete('${b.id}',deleteBird,'حذف ${esc(b.name||'الطير')}؟')">🗑️</button>
      </div>
    </div>
    <div class="bc-badges">
      <span class="badge" style="color:${sc.color};border-color:${sc.color}44;background:${sc.bg}">${sc.emoji} ${sc.label}</span>
      <span class="badge" style="color:${tc.color};border-color:${tc.color}44;background:#0a0a1a">${tc.emoji} ${tc.label}</span>
    </div>
    <div class="bc-grid">
      <div class="ib"><div class="ibl">💰 السعر</div><div class="ibv text-yel">${b.price?fmtMoney(b.price)+' '+DB.settings.currency:'—'}</div></div>
      <div class="ib"><div class="ibl">🎂 العمر</div><div class="ibv">${age}</div></div>
      ${eggRow}${buyerRow}${earningRow}
    </div>
    ${hatchHtml}
    ${b.notes?`<div class="bc-notes">📝 ${esc(b.notes)}</div>`:''}
    ${quickBtns?`<div class="bc-quickbtns">${quickBtns}</div>`:''}
  </div>`;
}

// ══════════════════════════════════
// FINANCE PAGE
// ══════════════════════════════════
function renderFinance(){
  const totalSales = DB.sales.reduce((s,x)=>s+(Number(x.amount)||0),0);
  const totalExp = DB.expenses.reduce((s,x)=>s+(Number(x.amount)||0),0);
  const profit = totalSales - totalExp;

  // Monthly data
  const months = {};
  [...DB.sales.map(x=>({...x,isIncome:true})), ...DB.expenses.map(x=>({...x,isIncome:false}))].forEach(x=>{
    const m = (x.date||today()).slice(0,7);
    if(!months[m]) months[m]={income:0,expense:0};
    if(x.isIncome) months[m].income+=Number(x.amount)||0; else months[m].expense+=Number(x.amount)||0;
  });
  const mKeys = Object.keys(months).sort().slice(-6);

  // Break-even per bird
  const birdBreakeven = DB.birds.filter(b=>b.purchasePrice).map(b=>{
    const spent = Number(b.purchasePrice)||0;
    const earned = DB.sales.filter(s=>s.birdId===b.id).reduce((s,x)=>s+(Number(x.amount)||0),0);
    return {name:b.name, spent, earned, reached: earned>=spent};
  });

  const catExpenses = {};
  DB.expenses.forEach(e=>{catExpenses[e.category]=(catExpenses[e.category]||0)+(Number(e.amount)||0);});

  const tabs = {
    summary:`
      <div class="fin-summary">
        <div class="fin-card" style="background:#051a09;border-color:#4ade8044"><div style="font-size:18px">📈</div><div class="fv text-g">${fmtMoney(totalSales)}</div><div class="fl text-g">المبيعات</div></div>
        <div class="fin-card" style="background:#1a0505;border-color:#f8717144"><div style="font-size:18px">📉</div><div class="fv text-red">${fmtMoney(totalExp)}</div><div class="fl text-red">المصاريف</div></div>
        <div class="fin-card" style="background:${profit>=0?'#051a09':'#1a0505'};border-color:${profit>=0?'#4ade8044':'#f8717144'}"><div style="font-size:18px">${profit>=0?'💵':'⚠️'}</div><div class="fv" style="color:${profit>=0?'#4ade80':'#f87171'}">${profit>=0?'+':''}${fmtMoney(profit)}</div><div class="fl" style="color:${profit>=0?'#4ade80':'#f87171'}">صافي الربح</div></div>
      </div>
      ${mKeys.length>1?`<div class="chart-container">
        <div class="section-title">آخر 6 أشهر</div>
        <canvas id="finance-chart" height="160"></canvas>
      </div>`:''}
      <div class="section-title">المصاريف حسب الفئة</div>
      ${Object.entries(catExpenses).map(([cat,amt])=>{
        const pct=totalExp>0?Math.round(amt/totalExp*100):0;
        return `<div class="transaction-item"><div class="ti-icon">📦</div><div class="ti-body"><div class="tib-title">${esc(cat)}</div><div style="height:4px;background:var(--brd);border-radius:2px;margin-top:4px;overflow:hidden"><div style="height:100%;width:${pct}%;background:var(--red);border-radius:2px"></div></div></div><div class="ti-amount text-red">${fmtMoney(amt)}</div></div>`;
      }).join('')||'<div class="empty-state"><div class="es-icon">📊</div><p>لا توجد مصاريف بعد</p></div>'}

      ${birdBreakeven.length?`<div class="section-title">نقطة التعادل لكل طير</div>${birdBreakeven.map(b=>`<div class="transaction-item"><div class="ti-icon">${b.reached?'✅':'⏳'}</div><div class="ti-body"><div class="tib-title">${esc(b.name)}</div><div class="tib-sub">دفعت: ${fmtMoney(b.spent)} • استرجعت: ${fmtMoney(b.earned)}</div></div><div class="ti-amount" style="color:${b.reached?'#4ade80':'#fbbf24'}">${b.reached?'ربح ✓':'—'}</div></div>`).join('')}`:''}
    `,
    sales:`
      <button class="btn btn-primary btn-block mb" onclick="openAddSale()">+ تسجيل بيعة</button>
      ${DB.sales.length===0?'<div class="empty-state"><div class="es-icon">💸</div><p>لا توجد مبيعات مسجلة</p></div>':
      [...DB.sales].reverse().map(s=>`<div class="transaction-item"><div class="ti-icon">💸</div><div class="ti-body"><div class="tib-title">${esc(s.birdName||'طير')}</div><div class="tib-sub">${s.buyer?'المشتري: '+esc(s.buyer)+' • ':''} ${fmtDate(s.date)}</div></div><div class="ti-amount text-g">+${fmtMoney(s.amount)}</div></div>`).join('')}
    `,
    expenses:`
      <button class="btn btn-primary btn-block mb" onclick="openAddExpense()">+ إضافة مصروف</button>
      ${DB.expenses.length===0?'<div class="empty-state"><div class="es-icon">📋</div><p>لا توجد مصاريف مسجلة</p></div>':
      [...DB.expenses].reverse().map(e=>`<div class="transaction-item"><div class="ti-icon">💸</div><div class="ti-body"><div class="tib-title">${esc(e.category)} — ${esc(e.notes||'')}</div><div class="tib-sub">${fmtDate(e.date)}</div></div><div class="ti-amount text-red">-${fmtMoney(e.amount)} <button class="btn btn-danger btn-sm" onclick="askDelete('${e.id}',deleteExpense,'حذف المصروف؟')">🗑️</button></div></div>`).join('')}
    `
  };

  const out = `
  <div class="tab-row">
    ${[['summary','📊 ملخص'],['sales','💸 المبيعات'],['expenses','📋 المصاريف']].map(([v,l])=>`<button class="tab-btn${finTab===v?' active':''}" onclick="finTab='${v}';refreshCurrent()">${l}</button>`).join('')}
  </div>
  ${tabs[finTab]||''}`;

  // Draw chart after render
  if(finTab==='summary'&&mKeys.length>1){
    setTimeout(()=>{
      const canvas = document.getElementById('finance-chart');
      if(!canvas) return;
      const ctx = canvas.getContext('2d');
      canvas.width = canvas.offsetWidth; canvas.height = 160;
      const w=canvas.width, h=160, pad=40, bw=Math.max(10,(w-pad*2)/(mKeys.length*2+mKeys.length));
      const maxVal = Math.max(1,...mKeys.map(m=>(months[m].income||0)+(months[m].expense||0)));
      ctx.clearRect(0,0,w,h);
      mKeys.forEach((m,i)=>{
        const inc=months[m].income||0, exp=months[m].expense||0;
        const x1=pad+(i*(bw*2+bw*.5)), x2=x1+bw;
        const iH=((inc/maxVal)*(h-50)), eH=((exp/maxVal)*(h-50));
        ctx.fillStyle='#16a34a88'; ctx.fillRect(x1,h-30-iH,bw,iH);
        ctx.fillStyle='#f8717188'; ctx.fillRect(x2,h-30-eH,bw,eH);
        ctx.fillStyle='#4b7a4b'; ctx.font='9px sans-serif'; ctx.textAlign='center';
        ctx.fillText(m.slice(5),x1+bw,h-15);
      });
    },50);
  }
  return out;
}

// ══════════════════════════════════
// BREEDING PAGE
// ══════════════════════════════════
function renderBreeding(){
  const STAGES = [
    {days:0,label:'بيضة',emoji:'🥚',color:'#fbbf24'},
    {days:7,label:'جنين',emoji:'🫀',color:'#f472b6'},
    {days:14,label:'نمو',emoji:'🌱',color:'#4ade80'},
    {days:0,label:'فقس',emoji:'🐣',color:'#fb923c'},
    {days:7,label:'زغب',emoji:'🐤',color:'#fbbf24'},
    {days:21,label:'ريش',emoji:'🐦',color:'#60a5fa'},
    {days:35,label:'فطام',emoji:'✈️',color:'#4ade80'},
  ];

  const pairsHtml = DB.breeding.length===0?`<div class="empty-state"><div class="es-icon">💑</div><p>لا توجد أزواج مسجلة</p><button class="btn btn-primary" onclick="openAddPair()">+ إضافة زوج</button></div>`:
  DB.breeding.map(pair=>{
    const male = DB.birds.find(b=>b.id===pair.maleId);
    const female = DB.birds.find(b=>b.id===pair.femaleId);
    const chicks = DB.birds.filter(b=>b.parentPairId===pair.id);
    let eggInfo='';
    if(pair.eggDate){
      const hdays=pair.hatchDays||21;
      const expH=pair.expectedHatch||addDays(pair.eggDate,hdays);
      const diff=daysDiff(today(),expH);
      const pct=Math.min(100,Math.round((daysDiff(pair.eggDate,today())/hdays)*100));
      const col=diff<=0?'#f87171':diff<=3?'#fbbf24':'#4ade80';
      eggInfo=`<div class="hatch-bar"><div class="hb-label"><span>🥚 ${pair.eggCount||'?'} بيضة • الفقس: ${fmtDate(expH)}</span><span style="color:${col};font-weight:700">${diff<=0?'اليوم/تأخر':diff+' يوم'}</span></div><div class="hb-track"><div class="hb-fill" style="width:${pct}%;background:${col}"></div></div></div>`;
    }
    const chicksHtml = chicks.length?`<div style="margin-top:8px;font-size:11px;color:var(--txt3);font-weight:700">الفراخ: ${chicks.map(c=>`<span style="display:inline-block;background:var(--bg);border-radius:6px;padding:2px 6px;margin:2px;font-size:11px;color:var(--g)">${esc(c.name||'فرخ')}</span>`).join('')}</div>`:'';
    return `<div class="pair-card">
      <div class="pair-header">
        <div class="pair-birds">🔵${esc(male?.name||'ذكر')} <span class="pair-separator">❤️</span> 🔴${esc(female?.name||'أنثى')}</div>
        <div class="flex-row">
          <button class="btn btn-secondary btn-sm" onclick="openEditPair('${pair.id}')">✏️</button>
          <button class="btn btn-danger btn-sm" onclick="askDelete('${pair.id}',deleteBreeding,'حذف هذا الزوج؟')">🗑️</button>
        </div>
      </div>
      ${pair.cage?`<div style="font-size:11px;color:var(--txt2);margin-bottom:6px">🏠 القفص: ${esc(pair.cage)}</div>`:''}
      ${eggInfo}
      ${chicksHtml}
      ${pair.notes?`<div class="bc-notes">📝 ${esc(pair.notes)}</div>`:''}
    </div>`;
  }).join('');

  // Family tree
  const treeHtml = `
  <div style="font-size:13px;color:var(--txt2);margin-bottom:10px">اختر طير لعرض شجرة عائلته:</div>
  <select id="tree-select" onchange="renderFamilyTree(this.value)" style="background:#0c1a0e;border:1px solid var(--brd);border-radius:10px;color:var(--txt);padding:9px 12px;font-family:var(--font);width:100%;margin-bottom:10px;font-size:13px;outline:none">
    <option value="">— اختر طير —</option>
    ${DB.birds.map(b=>`<option value="${b.id}">${esc(b.name||'بدون اسم')} (${b.type||'—'})</option>`).join('')}
  </select>
  <div id="family-tree-display"></div>`;

  const tabs = { pairs: pairsHtml, tree: treeHtml };
  return `
  <div class="tab-row">
    ${[['pairs','💑 الأزواج'],['tree','🌳 شجرة العائلة']].map(([v,l])=>`<button class="tab-btn${brdTab===v?' active':''}" onclick="brdTab='${v}';refreshCurrent()">${l}</button>`).join('')}
  </div>
  ${tabs[brdTab]||''}`;
}

function renderFamilyTree(birdId){
  const disp = document.getElementById('family-tree-display');
  if(!disp) return;
  if(!birdId){ disp.innerHTML=''; return; }
  const bird = DB.birds.find(b=>b.id===birdId);
  if(!bird){ disp.innerHTML=''; return; }
  
  const pair = DB.breeding.find(p=>p.id===bird.parentPairId);
  const male = pair?DB.birds.find(b=>b.id===pair.maleId):null;
  const female = pair?DB.birds.find(b=>b.id===pair.femaleId):null;
  const children = DB.birds.filter(b=>b.parentPairId&&DB.breeding.find(p=>p.id===b.parentPairId&&(p.maleId===birdId||p.femaleId===birdId)));

  disp.innerHTML = `
  <div style="background:var(--card);border:1px solid var(--brd);border-radius:var(--radius);padding:14px">
    ${pair?`<div style="margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--brd)">
      <div class="section-title">الوالدان</div>
      <div style="display:flex;gap:8px;justify-content:center">
        ${male?`<div style="background:var(--bg);border-radius:10px;padding:8px 12px;text-align:center;font-size:13px">🔵 ${esc(male.name||'أب')}<br><span style="font-size:10px;color:var(--txt3)">${male.type||''}</span></div>`:''}
        <div style="color:var(--pur);font-size:20px;align-self:center">❤️</div>
        ${female?`<div style="background:var(--bg);border-radius:10px;padding:8px 12px;text-align:center;font-size:13px">🔴 ${esc(female.name||'أم')}<br><span style="font-size:10px;color:var(--txt3)">${female.type||''}</span></div>`:''}
      </div>
    </div>`:'<div style="font-size:12px;color:var(--txt3);margin-bottom:12px">لا يوجد سجل للوالدين</div>'}
    <div style="text-align:center;padding:10px;background:var(--bg);border-radius:10px;font-weight:700;font-size:15px">
      ${(GENDER_CFG[bird.gender]||GENDER_CFG.unknown).emoji} ${esc(bird.name||'الطير')}
      <div style="font-size:11px;color:var(--txt3);margin-top:2px">${bird.type||''} ${bird.color?'• '+bird.color:''}</div>
    </div>
    ${children.length?`<div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--brd)">
      <div class="section-title">الأبناء</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        ${children.map(c=>`<div style="background:var(--bg);border-radius:8px;padding:6px 10px;font-size:12px">${(GENDER_CFG[c.gender]||GENDER_CFG.unknown).emoji} ${esc(c.name||'فرخ')}</div>`).join('')}
      </div>
    </div>`:''}
  </div>`;
}

// ══════════════════════════════════
// HEALTH PAGE
// ══════════════════════════════════
function renderHealth(){
  const tabs = {
    records:`
      <button class="btn btn-primary btn-block mb" onclick="openAddHealth()">+ إضافة سجل صحي</button>
      ${DB.health.length===0?`<div class="empty-state"><div class="es-icon">❤️</div><p>لا توجد سجلات صحية</p></div>`:
      [...DB.health].reverse().map(h=>{
        const bird = DB.birds.find(b=>b.id===h.birdId);
        const typeColors = {مرض:'#f87171',علاج:'#4ade80',فيتامين:'#fbbf24','زيارة طبيب':'#60a5fa',ملاحظة:'#c084fc','جرعة دواء':'#fb923c'};
        return `<div class="health-record"><div class="hr-dot" style="background:${typeColors[h.type]||'#6b7280'}"></div><div style="flex:1"><div style="font-size:13px;font-weight:700">${esc(bird?.name||'طير')} — ${h.type}</div><div style="font-size:11px;color:var(--txt2);margin:2px 0">${esc(h.notes||'')}</div><div style="font-size:10px;color:var(--txt3)">${fmtDate(h.date)}</div></div><button class="btn btn-danger btn-sm" onclick="askDelete('${h.id}',deleteHealth,'حذف السجل؟')">🗑️</button></div>`;
      }).join('')}
    `,
    reminders:`
      <button class="btn btn-primary btn-block mb" onclick="openAddReminder()">+ إضافة تذكير</button>
      ${DB.reminders.length===0?`<div class="empty-state"><div class="es-icon">🔔</div><p>لا توجد تذكيرات</p></div>`:
      DB.reminders.map(r=>{
        const overdue = r.nextDate<=today()&&!r.done;
        return `<div class="reminder-item" style="${overdue?'border-color:var(--yel)55':''}">
          <div class="ri-icon">${r.icon||'🔔'}</div>
          <div class="ri-body"><div class="rib-title">${esc(r.title)}</div><div class="rib-sub">${r.type} • ${fmtDate(r.nextDate)} ${overdue?'<span style="color:var(--yel);font-weight:700">• متأخر!</span>':''}</div></div>
          <div class="ri-actions">
            ${overdue?`<button class="btn btn-warn btn-sm" onclick="doneReminder('${r.id}')">✓</button>`:''}
            <button class="btn btn-danger btn-sm" onclick="askDelete('${r.id}',deleteReminder,'حذف التذكير؟')">🗑️</button>
          </div>
        </div>`;
      }).join('')}
      <div class="section-title" style="margin-top:14px">تذكيرات دورية مقترحة</div>
      <div style="display:flex;flex-direction:column;gap:7px">
        ${[['🚰','تغيير المياه','يومياً'],['🧹','تنظيف الأقفاص','أسبوعياً'],['💊','فيتامينات','أسبوعياً'],['🏥','تعقيم المكان','شهرياً'],['✂️','تقليم الأظافر','شهرياً'],['🐣','موعد فقس','مرة واحدة']].map(([ic,t,fr])=>`<div style="display:flex;align-items:center;justify-content:space-between;background:var(--card);border:1px solid var(--brd);border-radius:10px;padding:10px 12px"><span>${ic} ${t} (${fr})</span><button class="btn btn-secondary btn-sm" onclick="addQuickReminder('${t}','${ic}','${fr}')">+ إضافة</button></div>`).join('')}
      </div>
    `
  };
  return `
  <div class="tab-row">
    ${[['records','📋 السجلات'],['reminders','🔔 التذكيرات']].map(([v,l])=>`<button class="tab-btn${hlthTab===v?' active':''}" onclick="hlthTab='${v}';refreshCurrent()">${l}</button>`).join('')}
  </div>
  ${tabs[hlthTab]||''}`;
}

// ══════════════════════════════════
// GENES PAGE
// ══════════════════════════════════
function renderGenes(){
  const mutations = ['عادي','أوبالين','سيناموني','آينو (لوتينو/ألبينو)','سبانجل','هالو قين','باري','ريسيسيف باي','دومينانت باي'];
  return `
  <div style="font-size:13px;color:var(--txt2);margin-bottom:16px">اختر لون وطفرة الأب والأم لمعرفة الفراخ المحتملة (مخصص للبادجي)</div>
  <div class="card mb">
    <div class="section-title">الأب 🔵</div>
    <div class="form-grid">
      <div class="fg"><label>اللون الأساسي</label>
        <select id="g-male-color"><option value="">— اختر —</option>${Object.keys(BUD_COLORS).map(c=>`<option value="${c}">${c}</option>`).join('')}</select>
      </div>
      <div class="fg"><label>الطفرة الظاهرة</label>
        <select id="g-male-mut"><option value="">عادي</option>${mutations.slice(1).map(m=>`<option value="${m}">${m}</option>`).join('')}</select>
      </div>
      <div class="fg full"><label>طفرة مخفية (حامل)</label>
        <select id="g-male-hidden"><option value="">لا يوجد</option>${mutations.slice(1).map(m=>`<option value="${m}">${m}</option>`).join('')}</select>
      </div>
    </div>
    <div class="section-title" style="margin-top:12px">الأم 🔴</div>
    <div class="form-grid">
      <div class="fg"><label>اللون الأساسي</label>
        <select id="g-female-color"><option value="">— اختر —</option>${Object.keys(BUD_COLORS).map(c=>`<option value="${c}">${c}</option>`).join('')}</select>
      </div>
      <div class="fg"><label>الطفرة الظاهرة</label>
        <select id="g-female-mut"><option value="">عادي</option>${mutations.slice(1).map(m=>`<option value="${m}">${m}</option>`).join('')}</select>
      </div>
      <div class="fg full"><label>طفرة مخفية (حامل)</label>
        <select id="g-female-hidden"><option value="">لا يوجد</option>${mutations.slice(1).map(m=>`<option value="${m}">${m}</option>`).join('')}</select>
      </div>
    </div>
    <button class="btn btn-primary btn-block" style="margin-top:12px" onclick="calcGenes()">🧬 احسب الفراخ المحتملة</button>
  </div>
  <div id="gene-results"></div>
  <div class="card" style="margin-top:14px">
    <div class="section-title">معلومات الطفرات</div>
    ${[['الطفرات المرتبطة بالجنس (Sex-linked)','الآينو، الأوبالين، السيناموني — تورث من خلال الأم والأب بشكل مختلف بين الذكر والأنثى','#c084fc'],
       ['الطفرات الوراثية المتنحية (Recessive)','الريسيسيف باي — يجب أن يحمل الطرفان الجين ليظهر','#60a5fa'],
       ['الطفرات السائدة (Dominant)','السبانجل، الدومينانت باي — نسخة واحدة كافية للظهور','#fbbf24']
    ].map(([t,d,c])=>`<div style="margin-bottom:10px"><div style="font-size:13px;font-weight:700;color:${c};margin-bottom:3px">${t}</div><div style="font-size:12px;color:var(--txt2)">${d}</div></div>`).join('')}
  </div>`;
}

function calcGenes(){
  const mc = document.getElementById('g-male-color').value;
  const fc = document.getElementById('g-female-color').value;
  const mm = document.getElementById('g-male-mut').value;
  const fm = document.getElementById('g-female-mut').value;
  const mh = document.getElementById('g-male-hidden').value;
  const fh = document.getElementById('g-female-hidden').value;

  if(!mc||!fc){ showToast('⚠️ اختر لون الأب والأم','warn'); return; }

  const mData = BUD_COLORS[mc], fData = BUD_COLORS[fc];
  const results = [];

  // Base color calculation
  const bases = [];
  if(mData.base===fData.base) bases.push({color:mc,pct:50,note:'من الأب'},{color:fc,pct:50,note:'من الأم'});
  else {
    // Green × Blue = 50% split
    const gColor = mData.base==='green'?mc:fc;
    const bColor = mData.base==='blue'?mc:fc;
    bases.push({color:gColor,pct:50,note:'يحمل الجين الأزرق'},{color:bColor,pct:25,note:'مرئي'},{color:'أخضر/أزرق',pct:25,note:'حامل'});
  }

  // Dark factor
  const md=mData.dark||0, fd=fData.dark||0;
  const darkCombo=[];
  for(let i=0;i<=1;i++) for(let j=0;j<=1;j++){
    const d=Math.min(2,(i?md:Math.max(0,md-1))+(j?fd:Math.max(0,fd-1)));
    darkCombo.push(d);
  }

  const html = `<div class="gene-result">
    <div class="section-title">النتائج المحتملة</div>
    ${bases.map(b=>{
      const col = BUD_COLORS[b.color]?.color||'#6b7280';
      return `<div class="gene-result-row">
        <div class="gene-color-dot" style="background:${col}"></div>
        <div style="flex:1;margin-right:8px;font-size:13px;font-weight:700">${b.color}</div>
        <div class="gene-pct-bar"><div class="gene-pct-fill" style="width:${b.pct*2}%"></div></div>
        <div style="font-size:12px;font-weight:700;color:var(--g);min-width:35px;text-align:left">${b.pct}%</div>
      </div>`;
    }).join('')}
    ${mm||fm||mh||fh?`<div style="margin-top:10px;font-size:11px;color:var(--txt2);background:var(--bg);border-radius:8px;padding:8px">
      <div style="font-weight:700;margin-bottom:4px">ملاحظات الطفرات:</div>
      ${mm?`<div>• الأب يظهر: ${mm}</div>`:''}${fm?`<div>• الأم تظهر: ${fm}</div>`:''}
      ${mh?`<div>• الأب يحمل: ${mh} (مخفي)</div>`:''}${fh?`<div>• الأم تحمل: ${fh} (مخفي)</div>`:''}
      <div style="margin-top:4px;color:var(--yel)">للحصول على حسابات دقيقة للطفرات المعقدة يُنصح باستشارة متخصص في علم الوراثة.</div>
    </div>`:''}
  </div>`;
  document.getElementById('gene-results').innerHTML = html;
}

// ══════════════════════════════════
// SETTINGS PAGE
// ══════════════════════════════════
function renderSettings(){
  return `
  <div class="card mb">
    <div class="section-title">اسم المزرعة</div>
    <div class="flex-row">
      <input id="farm-name-input" style="flex:1;background:#091509;border:1px solid var(--brd2);border-radius:9px;color:var(--txt);padding:9px 11px;font-size:13px;outline:none;font-family:var(--font)" value="${esc(DB.settings.farmName)}">
      <button class="btn btn-primary btn-sm" onclick="saveFarmName()">حفظ</button>
    </div>
  </div>

  <div class="card mb">
    <div class="section-title">💱 العملة الافتراضية</div>
    <div class="flex-row">
      <select id="curr-set" onchange="saveCurrency(this.value)" style="flex:1;background:#091509;border:1px solid var(--brd2);border-radius:9px;color:var(--txt);padding:9px 11px;font-family:var(--font);font-size:13px;outline:none">
        <option value="IQD" ${DB.settings.currency==='IQD'?'selected':''}>🇮🇶 دينار عراقي (IQD)</option>
        <option value="USD" ${DB.settings.currency==='USD'?'selected':''}>🇺🇸 دولار أمريكي (USD)</option>
        <option value="SAR" ${DB.settings.currency==='SAR'?'selected':''}>🇸🇦 ريال سعودي (SAR)</option>
        <option value="AED" ${DB.settings.currency==='AED'?'selected':''}>🇦🇪 درهم إماراتي (AED)</option>
        <option value="EGP" ${DB.settings.currency==='EGP'?'selected':''}>🇪🇬 جنيه مصري (EGP)</option>
        <option value="TRY" ${DB.settings.currency==='TRY'?'selected':''}>🇹🇷 ليرة تركية (TRY)</option>
      </select>
      <div id="curr-rate-badge" style="font-size:11px;color:var(--txt2);min-width:90px;text-align:center">—</div>
    </div>
    <div id="curr-status" style="font-size:10px;color:var(--txt3);margin-top:6px"></div>
  </div>

  <div class="card mb">
    <div class="section-title">🔔 الإشعارات</div>
    <div style="font-size:13px;color:var(--txt2);margin-bottom:10px">تفعيل إشعارات الفقس والتذكيرات</div>
    <button class="btn btn-primary btn-block" onclick="reqNotif()">تفعيل الإشعارات</button>
  </div>

  <div class="card mb">
    <div class="section-title">📦 إدارة البيانات</div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <button class="btn btn-secondary btn-block" onclick="exportData()">📤 تصدير نسخة احتياطية (JSON)</button>
      <button class="btn btn-secondary btn-block" onclick="document.getElementById('import-file').click()">📥 استيراد نسخة احتياطية</button>
      <button class="btn btn-secondary btn-block" onclick="printReport()">🖨️ طباعة تقرير شامل</button>
      <button class="btn btn-danger btn-block" onclick="askDelete(null,clearAllData,'مسح جميع البيانات؟ ⚠️ لا يمكن التراجع!')">🗑️ مسح جميع البيانات</button>
    </div>
  </div>

  <div class="card mb" id="qr-section">
    <div class="section-title">📱 QR Code للأقفاص</div>
    <div style="font-size:12px;color:var(--txt2);margin-bottom:10px">اختر طير لتوليد QR Code لقفصه</div>
    <select id="qr-bird-select" onchange="generateQR(this.value)" style="background:#091509;border:1px solid var(--brd2);border-radius:9px;color:var(--txt);padding:9px 11px;font-family:var(--font);width:100%;margin-bottom:10px;font-size:13px;outline:none">
      <option value="">— اختر طير —</option>
      ${DB.birds.map(b=>`<option value="${b.id}">${esc(b.name||'بدون اسم')} (${b.type||'—'})</option>`).join('')}
    </select>
    <div id="qr-display" style="text-align:center;padding:10px"></div>
  </div>

  <div class="card">
    <div class="section-title">📊 إحصائيات المزرعة</div>
    ${[
      ['🦜 إجمالي الطيور', DB.birds.length],
      ['💰 إجمالي المبيعات', fmtMoney(DB.sales.reduce((s,x)=>s+(Number(x.amount)||0),0))+' '+DB.settings.currency],
      ['📋 إجمالي المصاريف', fmtMoney(DB.expenses.reduce((s,x)=>s+(Number(x.amount)||0),0))+' '+DB.settings.currency],
      ['❤️ السجلات الصحية', DB.health.length],
      ['🥚 أزواج التكاثر', DB.breeding.length],
    ].map(([l,v])=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--brd);font-size:13px"><span style="color:var(--txt2)">${l}</span><span style="font-weight:700">${v}</span></div>`).join('')}
  </div>`;
}

function saveFarmName(){
  const n = document.getElementById('farm-name-input').value.trim();
  if(!n) return;
  DB.settings.farmName = n;
  saveDB();
  document.getElementById('hdr-title').textContent = '🦜 '+n;
  showToast('✅ تم حفظ الاسم');
}

function generateQR(birdId){
  const disp = document.getElementById('qr-display');
  if(!disp) return;
  if(!birdId){ disp.innerHTML=''; return; }
  const bird = DB.birds.find(b=>b.id===birdId);
  if(!bird){ disp.innerHTML=''; return; }
  const data = encodeURIComponent(`${DB.settings.farmName} | ${bird.name||'طير'} | ${bird.type||''} | ${bird.color||''} | ${bird.status}`);
  disp.innerHTML = `<img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${data}&bgcolor=ffffff&color=052e16" style="border-radius:12px;background:white;padding:8px;max-width:200px"><div style="font-size:11px;color:var(--txt2);margin-top:8px">${esc(bird.name||'')} — ${esc(bird.type||'')}</div><button class="btn btn-secondary btn-sm" style="margin-top:8px" onclick="downloadQR('${data}','${esc(bird.name||'bird')}')">⬇️ تحميل</button>`;
}

function downloadQR(data, name){
  const a = document.createElement('a');
  a.href = `https://api.qrserver.com/v1/create-qr-code/?size=400x400&data=${data}`;
  a.download = `qr-${name}.png`; a.target='_blank'; a.click();
}

// ══════════════════════════════════
// MODALS — BIRD
// ══════════════════════════════════
function openAddBird(){ editingId=null; openBirdModal(null); }
function openEditBird(id){ editingId=id; openBirdModal(DB.birds.find(b=>b.id===id)); }

function openBirdModal(b){
  document.getElementById('modal-title-text').textContent = b?'✏️ تعديل الطير':'🐦 إضافة طير جديد';
  const pairOptions = DB.breeding.map(p=>`<option value="${p.id}" ${b?.parentPairId===p.id?'selected':''}>${esc(DB.birds.find(x=>x.id===p.maleId)?.name||'ذكر')} ❤️ ${esc(DB.birds.find(x=>x.id===p.femaleId)?.name||'أنثى')}</option>`).join('');
  document.getElementById('modal-body').innerHTML = `
  <div class="form-grid">
    <div class="fg"><label>الاسم *</label><input id="fb-name" placeholder="مثال: سكر" value="${esc(b?.name||'')}"></div>
    <div class="fg"><label>اللون/الطفرة</label><input id="fb-color" placeholder="أزرق كوبالت" value="${esc(b?.color||'')}"></div>
    <div class="fg"><label>النوع</label><select id="fb-type" onchange="onFbTypeChange()"><option value="">اختر</option><optgroup label="── ببغاوات ──">${PARROT_TYPES.map(t=>`<option value="${t}"${b?.type===t?' selected':''}>${t}</option>`).join('')}</optgroup><optgroup label="── باقي الطيور ──">${OTHER_TYPES.map(t=>`<option value="${t}"${b?.type===t?' selected':''}>${t}</option>`).join('')}</optgroup></select></div>
    <div class="fg"><label>الجنس</label><select id="fb-gender"><option value="male"${b?.gender==='male'?' selected':''}>ذكر 🔵</option><option value="female"${b?.gender==='female'?' selected':''}>أنثى 🔴</option><option value="unknown"${b?.gender==='unknown'?' selected':''}>غير محدد ⚪</option></select></div>
    <div class="fg"><label>الحالة</label><select id="fb-status" onchange="onFbStatusChange()"><option value="available"${b?.status==='available'?' selected':''}>🟢 متوفر</option><option value="sold"${b?.status==='sold'?' selected':''}>🔴 مُباع</option><option value="eggs"${b?.status==='eggs'?' selected':''}>🥚 البيض</option><option value="hatched"${b?.status==='hatched'?' selected':''}>🐣 فقست</option><option value="dead"${b?.status==='dead'?' selected':''}>🪦 نافق</option></select></div>
    <div class="fg"><label>الأُلفة</label><select id="fb-tame"><option value="tame"${b?.tame==='tame'?' selected':''}>💚 أليف</option><option value="wild"${b?.tame==='wild'?' selected':''}>⚡ مو أليف</option></select></div>
    <div class="fg"><label>السعر (${DB.settings.currency})</label><input id="fb-price" type="number" min="0" placeholder="0" value="${b?.price||''}"></div>
    <div class="fg"><label>سعر الشراء</label><input id="fb-purchase" type="number" min="0" placeholder="0" value="${b?.purchasePrice||''}"></div>
    <div class="fg"><label>تاريخ الميلاد</label><input id="fb-birth" type="date" value="${b?.birthDate||''}"></div>
    <div class="fg"><label>تاريخ الشراء</label><input id="fb-buydate" type="date" value="${b?.buyDate||''}"></div>
    ${pairOptions?`<div class="fg full"><label>الوالدان (لتتبع الأنساب)</label><select id="fb-pair"><option value="">— لا يوجد —</option>${pairOptions}</select></div>`:''}
    <div class="form-divider">تفاصيل البيض والتكاثر</div>
    <div class="fg" id="fbg-eggdate"><label>تاريخ وضع البيض</label><input id="fb-eggdate" type="date" onchange="onFbEggChange()" value="${b?.eggDate||''}"></div>
    <div class="fg" id="fbg-eggcount"><label>عدد البيض</label><input id="fb-eggcount" type="number" min="0" placeholder="0" value="${b?.eggCount||''}"></div>
    <div class="fg" id="fbg-hdays"><label>أيام الحضانة</label><input id="fb-hdays" type="number" min="1" max="40" placeholder="21" onchange="onFbEggChange()" value="${b?.hatchDays||getHatchDays(b?.type||'')}"></div>
    <div class="fg" id="fbg-exphatch"><label>الفقس المتوقع</label><input id="fb-exphatch" type="date" value="${b?.expectedHatch||''}"></div>
    <div id="fbg-preview" class="hatch-preview-box" style="display:none"></div>
    <div class="fg" id="fbg-hcount"><label>عدد اللي فقست</label><input id="fb-hcount" type="number" min="0" placeholder="0" value="${b?.hatchCount||''}"></div>
    <div class="fg" id="fbg-ahatch"><label>تاريخ الفقس الفعلي</label><input id="fb-ahatch" type="date" value="${b?.actualHatch||''}"></div>
    <div class="form-divider">البيع والملاحظات</div>
    <div class="fg" id="fbg-buyer"><label>اسم المشتري</label><input id="fb-buyer" placeholder="اسم المشتري" value="${esc(b?.buyer||'')}"></div>
    <div class="fg"><label>آخر زيارة طبيب</label><input id="fb-vet" type="date" value="${b?.vetDate||''}"></div>
    <div class="fg full"><label>ملاحظات</label><textarea id="fb-notes">${esc(b?.notes||'')}</textarea></div>
  </div>
  <div class="flex-row" style="margin-top:16px;gap:8px">
    <button class="btn btn-primary" style="flex:1;justify-content:center;padding:12px" onclick="saveBirdModal()">✓ حفظ</button>
    <button class="btn btn-secondary" style="flex:1;justify-content:center;padding:12px" onclick="closeModal()">إلغاء</button>
  </div>`;
  onFbStatusChange();
  openModal();
}

function onFbTypeChange(){
  const t = document.getElementById('fb-type')?.value;
  const d = getHatchDays(t);
  const hd = document.getElementById('fb-hdays');
  if(hd&&!hd.value) hd.value = d;
  onFbEggChange();
}

function onFbStatusChange(){
  const s = document.getElementById('fb-status')?.value;
  const showEgg = ['eggs','hatched'].includes(s);
  ['fbg-eggdate','fbg-eggcount','fbg-hdays','fbg-exphatch','fbg-preview'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.style.display=showEgg?'':'none';
  });
  ['fbg-hcount','fbg-ahatch'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.style.display=s==='hatched'?'':'none';
  });
  const buyerEl = document.getElementById('fbg-buyer');
  if(buyerEl) buyerEl.style.display=s==='sold'?'':'none';
  onFbEggChange();
}

function onFbEggChange(){
  const ed = document.getElementById('fb-eggdate')?.value;
  const hd = parseInt(document.getElementById('fb-hdays')?.value)||21;
  const prev = document.getElementById('fbg-preview');
  if(!ed||!prev){ if(prev) prev.style.display='none'; return; }
  const expH = addDays(ed, hd);
  document.getElementById('fb-exphatch').value = expH;
  const diff = daysDiff(today(), expH);
  const lab = diff===0?'اليوم! 🚨':diff>0?`بعد ${diff} يوم`:`تأخر ${Math.abs(diff)} يوم`;
  prev.style.display='';
  prev.innerHTML = `🐣 الفقس المتوقع: <strong>${fmtDate(expH)}</strong> — ${lab}`;
}

function saveBirdModal(){
  const name = document.getElementById('fb-name')?.value.trim();
  if(!name){ showToast('⚠️ أدخل اسم الطير','warn'); return; }
  const bird = {
    name, color:document.getElementById('fb-color')?.value.trim(),
    type:document.getElementById('fb-type')?.value, gender:document.getElementById('fb-gender')?.value,
    status:document.getElementById('fb-status')?.value, tame:document.getElementById('fb-tame')?.value,
    price:document.getElementById('fb-price')?.value, purchasePrice:document.getElementById('fb-purchase')?.value,
    birthDate:document.getElementById('fb-birth')?.value, buyDate:document.getElementById('fb-buydate')?.value,
    eggDate:document.getElementById('fb-eggdate')?.value, eggCount:document.getElementById('fb-eggcount')?.value,
    hatchDays:document.getElementById('fb-hdays')?.value, expectedHatch:document.getElementById('fb-exphatch')?.value,
    hatchCount:document.getElementById('fb-hcount')?.value, actualHatch:document.getElementById('fb-ahatch')?.value,
    buyer:document.getElementById('fb-buyer')?.value?.trim(), vetDate:document.getElementById('fb-vet')?.value,
    notes:document.getElementById('fb-notes')?.value?.trim(),
    parentPairId:document.getElementById('fb-pair')?.value||null,
    notifiedToday:false, notifiedTmr:false,
  };
  if(editingId){ DB.birds=DB.birds.map(b=>b.id===editingId?{...b,...bird}:b); showToast('✅ تم التحديث'); }
  else{ bird.id=uid(); bird.createdAt=today(); DB.birds.push(bird); showToast('✅ تم إضافة الطير'); }
  saveDB(); closeModal(); refreshCurrent();
}


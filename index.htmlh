function openAddHealth(){
  document.getElementById('modal-title-text').textContent='❤️ إضافة سجل صحي';
  document.getElementById('modal-body').innerHTML=`
  <div class="form-grid">
    <div class="fg full"><label>الطير</label><select id="fh-bird"><option value="">— اختر طير —</option>${DB.birds.filter(b=>b.status!=='dead').map(b=>`<option value="${b.id}">${esc(b.name||'طير')}</option>`).join('')}</select></div>
    <div class="fg"><label>النوع</label><select id="fh-type">${HEALTH_TYPES.map(t=>`<option value="${t}">${t}</option>`).join('')}</select></div>
    <div class="fg"><label>التاريخ</label><input id="fh-date" type="date" value="${today()}"></div>
    <div class="fg full"><label>الوصف والعلاج</label><textarea id="fh-notes" placeholder="صف الحالة أو العلاج المستخدم..."></textarea></div>
  </div>
  <button class="btn btn-primary btn-block" style="margin-top:14px" onclick="saveHealth()">✓ حفظ</button>`;
  openModal();
}

function saveHealth(){
  const birdId = document.getElementById('fh-bird')?.value;
  const notes = document.getElementById('fh-notes')?.value?.trim();
  if(!birdId){ showToast('⚠️ اختر طير','warn'); return; }
  DB.health.push({id:uid(),birdId,type:document.getElementById('fh-type')?.value,date:document.getElementById('fh-date')?.value||today(),notes});
  saveDB(); closeModal(); hlthTab='records'; refreshCurrent(); showToast('✅ تم حفظ السجل الصحي');
}

function openAddReminder(){
  document.getElementById('modal-title-text').textContent='🔔 إضافة تذكير';
  document.getElementById('modal-body').innerHTML=`
  <div class="form-grid">
    <div class="fg full"><label>العنوان</label><input id="fr-title" placeholder="مثال: تعقيم الأقفاص"></div>
    <div class="fg"><label>النوع</label><select id="fr-type">${REM_TYPES.map(t=>`<option value="${t}">${t}</option>`).join('')}</select></div>
    <div class="fg"><label>الأيقونة</label><input id="fr-icon" placeholder="🔔" maxlength="2" value="🔔"></div>
    <div class="fg"><label>التاريخ</label><input id="fr-date" type="date" value="${today()}"></div>
    <div class="fg"><label>التكرار</label><select id="fr-repeat"><option value="once">مرة واحدة</option><option value="daily">يومي</option><option value="weekly">أسبوعي</option><option value="monthly">شهري</option></select></div>
  </div>
  <button class="btn btn-primary btn-block" style="margin-top:14px" onclick="saveReminder()">✓ إضافة</button>`;
  openModal();
}

function saveReminder(){
  const title=document.getElementById('fr-title')?.value?.trim();
  if(!title){ showToast('⚠️ أدخل العنوان','warn'); return; }
  DB.reminders.push({id:uid(),title,type:document.getElementById('fr-type')?.value,icon:document.getElementById('fr-icon')?.value||'🔔',nextDate:document.getElementById('fr-date')?.value||today(),repeat:document.getElementById('fr-repeat')?.value,done:false});
  saveDB(); closeModal(); hlthTab='reminders'; refreshCurrent(); showToast('✅ تم إضافة التذكير');
}

function addQuickReminder(title, icon, freq){
  const repeatMap={'يومياً':'daily','أسبوعياً':'weekly','شهرياً':'monthly'};
  DB.reminders.push({id:uid(),title,type:title,icon,nextDate:today(),repeat:repeatMap[freq]||'weekly',done:false});
  saveDB(); refreshCurrent(); showToast('✅ تم إضافة التذكير: '+title);
}

function doneReminder(id){
  const rem = DB.reminders.find(r=>r.id===id);
  if(!rem) return;
  if(rem.repeat==='daily') rem.nextDate=addDays(today(),1);
  else if(rem.repeat==='weekly') rem.nextDate=addDays(today(),7);
  else if(rem.repeat==='monthly') rem.nextDate=addDays(today(),30);
  else { rem.done=true; }
  saveDB(); refreshCurrent(); showToast('✅ تم! التذكير القادم: '+fmtDate(rem.nextDate));
}

// ══════════════════════════════════
// QUICK ACTIONS
// ══════════════════════════════════
function quickHatch(birdId){
  const count = prompt('كم عدد الفراخ اللي فقست؟');
  if(count===null) return;
  DB.birds = DB.birds.map(b=>b.id===birdId?{...b,status:'hatched',actualHatch:today(),hatchCount:count}:b);
  saveDB(); refreshCurrent(); showToast('🐣 تم تسجيل الفقس!');
}
function quickSell(birdId){
  const bird = DB.birds.find(b=>b.id===birdId);
  const buyer = prompt('اسم المشتري (اختياري):','') ?? '';
  if(buyer===null) return;
  const price = bird?.price||0;
  DB.birds = DB.birds.map(b=>b.id===birdId?{...b,status:'sold',buyer}:b);
  if(price) DB.sales.push({id:uid(),birdId,birdName:bird?.name||'طير',buyer,amount:price,date:today()});
  saveDB(); refreshCurrent(); showToast('💸 تم تسجيل البيع!');
}
function quickEggs(birdId){
  const bird = DB.birds.find(b=>b.id===birdId);
  const count = prompt('كم عدد البيض؟','') ?? '';
  if(count===null) return;
  const eggDate=today(), hd=getHatchDays(bird?.type), expH=addDays(eggDate,hd);
  DB.birds = DB.birds.map(b=>b.id===birdId?{...b,status:'eggs',eggDate,eggCount:count,hatchDays:hd,expectedHatch:expH,notifiedToday:false,notifiedTmr:false}:b);
  saveDB(); refreshCurrent(); showToast('🥚 تم! الفقس المتوقع: '+fmtDate(expH));
}

function showQR(birdId){
  const bird = DB.birds.find(b=>b.id===birdId);
  if(!bird) return;
  const data = encodeURIComponent(`${DB.settings.farmName}|${bird.name||'طير'}|${bird.type||''}|${bird.color||''}`);
  document.getElementById('modal-title-text').textContent='📱 QR Code — '+esc(bird.name||'طير');
  document.getElementById('modal-body').innerHTML=`<div style="text-align:center;padding:10px"><img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=${data}&bgcolor=ffffff&color=052e16" style="border-radius:12px;padding:8px;background:white;max-width:220px"><div style="margin-top:12px;font-size:13px;color:var(--txt2)">${esc(bird.name||'طير')} — ${esc(bird.type||'')} ${esc(bird.color||'')}</div><div style="margin-top:8px;font-size:11px;color:var(--txt3)">امسح بالكاميرا لعرض بيانات الطير</div><button class="btn btn-primary btn-block" style="margin-top:12px" onclick="shareWhatsApp('${esc(bird.name||'طير')}','${esc(bird.type||'')}','${esc(bird.status)}','${esc(bird.price||'')}')">📤 مشاركة عبر واتساب</button></div>`;
  openModal();
}

function showMarketPrice(type){
  const group = MARKET_PRICES[type];
  if(!group) return;
  const currency = DB.settings.currency || 'IQD';
  const meta = CURRENCY_META[currency] || {sym: currency};
  const fmt = n => {
    if(n>=1000000) return (n/1000000).toFixed(1)+'M';
    if(n>=1000)    return Math.round(n/1000)+'K';
    return Math.round(n).toLocaleString('ar');
  };
  const rows = group.items.map(item => {
    const convMin = convertFromSAR(item.min, currency);
    const convMax = convertFromSAR(item.max, currency);
    const priceStr = currency==='IQD'
      ? fmtIQD(item.min)+' — '+fmtIQD(item.max)+' د.ع'
      : fmt(convMin)+' — '+fmt(convMax)+' '+meta.sym;
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 10px;background:var(--bg);border-radius:8px;border:1px solid var(--brd);margin-bottom:5px">
      <div>
        <div style="font-size:13px;font-weight:700">${item.name}</div>
        ${item.notes?`<div style="font-size:10px;color:var(--txt3)">${item.notes}</div>`:''}
      </div>
      <div style="font-size:11px;font-weight:800;color:var(--yel);white-space:nowrap;margin-right:8px">${priceStr}</div>
    </div>`;
  }).join('');
  document.getElementById('modal-title-text').textContent=group.emoji+' سعر السوق — '+group.label;
  document.getElementById('modal-body').innerHTML=`<div style="padding:4px 0">
    ${rows}
    <div style="font-size:10px;color:var(--txt3);margin-top:10px;text-align:center">🇮🇶 أسعار وحشيات تقريبية من السوق العراقي</div>
  </div>`;
  openModal();
}

function shareWhatsApp(name, type, status, price){
  const sc = STATUS_CFG[status]||STATUS_CFG.available;
  const msg = encodeURIComponent(`🦜 *${name}* للبيع!\n📌 النوع: ${type}\n${price?'💰 السعر: '+price+' '+DB.settings.currency+'\n':''}${sc.emoji} الحالة: ${sc.label}\n\n— ${DB.settings.farmName}`);
  window.open('https://wa.me/?text='+msg,'_blank');
}

// ══════════════════════════════════
// DELETE / CRUD
// ══════════════════════════════════
function deleteBird(id){ DB.birds=DB.birds.filter(b=>b.id!==id); saveDB(); refreshCurrent(); showToast('🗑️ تم حذف الطير'); }
function deleteExpense(id){ DB.expenses=DB.expenses.filter(e=>e.id!==id); saveDB(); refreshCurrent(); showToast('🗑️ تم الحذف'); }
function deleteHealth(id){ DB.health=DB.health.filter(h=>h.id!==id); saveDB(); refreshCurrent(); showToast('🗑️ تم الحذف'); }
function deleteReminder(id){ DB.reminders=DB.reminders.filter(r=>r.id!==id); saveDB(); refreshCurrent(); showToast('🗑️ تم الحذف'); }
function deleteBreeding(id){ DB.breeding=DB.breeding.filter(p=>p.id!==id); saveDB(); refreshCurrent(); showToast('🗑️ تم الحذف'); }
function clearAllData(){
  DB={birds:[],expenses:[],sales:[],breeding:[],health:[],reminders:[],settings:{farmName:'مزرعة طيوري',currency:'IQD'}};
  saveDB(); showToast('🗑️ تم مسح جميع البيانات'); refreshCurrent();
}

// ══════════════════════════════════
// CONFIRM DIALOG
// ══════════════════════════════════
function askDelete(id, fn, msg='هل أنت متأكد؟'){
  deleteTarget={id,fn};
  document.getElementById('ci-msg').textContent=msg;
  document.getElementById('confirm-overlay').classList.add('open');
  document.getElementById('ci-yes').onclick=()=>{if(deleteTarget){deleteTarget.fn(deleteTarget.id);}closeConfirm();};
}
function closeConfirm(){ document.getElementById('confirm-overlay').classList.remove('open'); deleteTarget=null; }

// ══════════════════════════════════
// MODAL
// ══════════════════════════════════
function openModal(){ document.getElementById('modal-overlay').classList.add('open'); }
function closeModal(){ document.getElementById('modal-overlay').classList.remove('open'); editingId=null; }
function handleMOverlay(e){ if(e.target===document.getElementById('modal-overlay')) closeModal(); }

// ══════════════════════════════════
// NOTIFICATIONS
// ══════════════════════════════════
async function reqNotif(){
  if(!('Notification' in window)){ showToast('⚠️ المتصفح لا يدعم الإشعارات','warn'); return; }
  const r=await Notification.requestPermission();
  showToast(r==='granted'?'✅ تم تفعيل الإشعارات!':'⚠️ لم يتم تفعيل الإشعارات','warn');
}

function checkNotifications(){
  const tod=today(), tmr=addDays(tod,1);
  DB.birds.forEach(bird=>{
    if(bird.status!=='eggs'||!bird.expectedHatch) return;
    if(bird.expectedHatch===tod&&!bird.notifiedToday){
      if(Notification.permission==='granted') new Notification('🐣 موعد الفقس اليوم!',{body:`طيرك "${bird.name}" حان موعد فقسه اليوم!`});
      DB.birds=DB.birds.map(b=>b.id===bird.id?{...b,notifiedToday:true}:b); saveDB();
    }
    if(bird.expectedHatch===tmr&&!bird.notifiedTmr){
      if(Notification.permission==='granted') new Notification('⏰ الفقس بكرة!',{body:`طيرك "${bird.name}" سيفقس غداً!`});
      DB.birds=DB.birds.map(b=>b.id===bird.id?{...b,notifiedTmr:true}:b); saveDB();
    }
  });
  DB.reminders.forEach(rem=>{
    if(rem.nextDate===tod&&!rem.done&&Notification.permission==='granted'){
      new Notification('🔔 '+rem.title,{body:rem.type});
    }
  });
}

// ══════════════════════════════════
// EXPORT / IMPORT / PRINT
// ══════════════════════════════════
function exportData(){
  const blob=new Blob([JSON.stringify({version:VER,date:today(),data:DB},null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`مزرعتي-${today()}.json`; a.click();
  showToast('📤 تم التصدير');
}

function handleImport(e){
  const file=e.target.files[0]; if(!file) return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const parsed=JSON.parse(ev.target.result);
      const d=parsed.data||parsed;
      if(!d.birds) throw new Error();
      if(!confirm('دمج مع البيانات الحالية؟ (موافق=دمج، إلغاء=استبدال)')) DB=Object.assign(DB,d);
      else{
        const existIds=new Set(DB.birds.map(b=>b.id));
        (d.birds||[]).forEach(b=>{if(!existIds.has(b.id))DB.birds.push(b);});
      }
      saveDB(); showPage(currentPage); showToast('✅ تم الاستيراد بنجاح');
    }catch{showToast('❌ ملف غير صالح','err');}
  };
  r.readAsText(file); e.target.value='';
}

function printReport(){
  const win=window.open('','_blank');
  const totalSales=DB.sales.reduce((s,x)=>s+(Number(x.amount)||0),0);
  const totalExp=DB.expenses.reduce((s,x)=>s+(Number(x.amount)||0),0);
  win.document.write(`<!DOCTYPE html><html dir="rtl" lang="ar"><head><meta charset="UTF-8"><title>تقرير ${esc(DB.settings.farmName)}</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;700&display=swap" rel="stylesheet">
  <style>body{font-family:'Noto Kufi Arabic',sans-serif;direction:rtl;padding:24px;color:#111}h1{color:#16a34a;margin-bottom:4px}table{width:100%;border-collapse:collapse;font-size:12px;margin:12px 0}th{background:#052e16;color:#4ade80;padding:8px;text-align:right}td{padding:7px 8px;border-bottom:1px solid #e5e7eb}tr:nth-child(even){background:#f9fafb}.stat{display:inline-block;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:8px 14px;margin:4px;text-align:center}.stat b{display:block;font-size:20px;color:#16a34a}@media print{button{display:none}}</style></head>
  <body><h1>🦜 ${esc(DB.settings.farmName)}</h1><p style="color:#666;font-size:12px">تاريخ التقرير: ${fmtDate(today())} • إجمالي: ${DB.birds.length} طير</p>
  <div style="margin:12px 0">
    <div class="stat"><b>${DB.birds.filter(b=>b.status==='available').length}</b>متوفر</div>
    <div class="stat"><b>${DB.birds.filter(b=>b.status==='sold').length}</b>مُباع</div>
    <div class="stat"><b>${DB.birds.filter(b=>b.status==='eggs').length}</b>البيض</div>
    <div class="stat"><b style="color:#16a34a">${fmtMoney(totalSales)} ر</b>المبيعات</div>
    <div class="stat"><b style="color:#dc2626">${fmtMoney(totalExp)} ر</b>المصاريف</div>
    <div class="stat"><b style="color:${totalSales-totalExp>=0?'#16a34a':'#dc2626'}">${fmtMoney(totalSales-totalExp)} ر</b>صافي الربح</div>
  </div>
  <h3>الطيور</h3>
  <table><thead><tr><th>الاسم</th><th>النوع</th><th>اللون</th><th>الجنس</th><th>الحالة</th><th>السعر</th><th>العمر</th><th>المشتري</th></tr></thead>
  <tbody>${DB.birds.map(b=>`<tr><td>${esc(b.name||'—')}</td><td>${esc(b.type||'—')}</td><td>${esc(b.color||'—')}</td><td>${(GENDER_CFG[b.gender]||GENDER_CFG.unknown).label}</td><td>${(STATUS_CFG[b.status]||STATUS_CFG.available).label}</td><td>${b.price?fmtMoney(b.price)+' ر':'—'}</td><td>${exactAge(b.birthDate)}</td><td>${esc(b.buyer||'—')}</td></tr>`).join('')}</tbody></table>
  <h3>آخر المصاريف</h3>
  <table><thead><tr><th>الفئة</th><th>الملاحظات</th><th>التاريخ</th><th>المبلغ</th></tr></thead>
  <tbody>${[...DB.expenses].reverse().slice(0,20).map(e=>`<tr><td>${esc(e.category)}</td><td>${esc(e.notes||'—')}</td><td>${fmtDate(e.date)}</td><td style="color:#dc2626">-${fmtMoney(e.amount)} ر</td></tr>`).join('')}</tbody></table>
  <br><button onclick="window.print()">🖨️ طباعة</button></body></html>`);
  win.document.close();
}

// ══════════════════════════════════
// TOAST
// ══════════════════════════════════
function showToast(msg, type=''){
  const w=document.getElementById('toast-wrap');
  const t=document.createElement('div');
  t.className='toast'+(type?' '+type:'');
  t.textContent=msg; w.appendChild(t);
  setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .3s';setTimeout(()=>t.remove(),300);},3000);
}

// ══════════════════════════════════
// KEYBOARD
// ══════════════════════════════════
document.addEventListener('keydown',e=>{ if(e.key==='Escape'){closeModal();closeConfirm();} });

// ══════════════════════════════════
// MARKET BOURSE + CURRENCY CONVERTER
// ══════════════════════════════════

// الأسعار الأساسية للطيور مخزّنة بالدولار الأمريكي (USD) كعملة مرجعية محايدة
const MARKET_PRICES_USD = (() => {
  // سيتم تحويل MARKET_PRICES (المُعرَّفة بـ SAR) إلى USD لاحقاً عند جلب السعر
  // لكن نحتفظ هنا بجدول الأسعار الأصلي بـ SAR ونحوّله ديناميكياً
  return null; // placeholder — الحسابات تتم في convertPrice()
})();

// رموز العملات وأسماؤها
const CURRENCY_META = {
  IQD: { sym: 'د.ع', name: 'دينار عراقي',  flag: '🇮🇶' },
  USD: { sym: '$',   name: 'دولار أمريكي',  flag: '🇺🇸' },
  SAR: { sym: 'ر.س', name: 'ريال سعودي',   flag: '🇸🇦' },
  AED: { sym: 'د.إ', name: 'درهم إماراتي', flag: '🇦🇪' },
  EGP: { sym: 'ج.م', name: 'جنيه مصري',   flag: '🇪🇬' },
  TRY: { sym: '₺',   name: 'ليرة تركية',   flag: '🇹🇷' },
};

// كاش أسعار الصرف: { USD: 1, SAR: 3.75, IQD: 1310, ... }
let ratesCache = null;   // أسعار من الإنترنت (أساس USD)
let ratesFetchedAt = null;
const RATES_TTL = 10 * 60 * 1000; // 10 دقائق

// أسعار احتياطية من الدولار (تُستخدم عند فشل الاتصال)
const FALLBACK_RATES = {
  USD: 1,
  SAR: 3.75,
  AED: 3.67,
  EGP: 48.5,
  IQD: 1310,
  TRY: 32.5,
};

// أسعار الطيور الأساسية مُعرَّفة بـ IQD في MARKET_PRICES أعلاه
// دالة التحويل الديناميكي: من IQD إلى أي عملة
function convertFromSAR(amountIQD, toCurrency) {
  if (!amountIQD) return 0;
  const amount = Number(amountIQD);
  if (toCurrency === 'IQD') return amount;
  const rates = ratesCache || FALLBACK_RATES;
  const iqdRate = rates['IQD'] || FALLBACK_RATES['IQD']; // IQD per USD
  const toRate  = rates[toCurrency] || FALLBACK_RATES[toCurrency] || 1;
  // amount (IQD) → USD → toCurrency
  const usd = amount / iqdRate;
  return usd * toRate;
}

function fmtConvertedPrice(min, max, currency) {
  const meta = CURRENCY_META[currency] || { sym: currency };
  const convMin = convertFromSAR(min, currency);
  const convMax = convertFromSAR(max, currency);
  const fmt = n => {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
    if (n >= 1_000)     return (n / 1_000).toFixed(n >= 10_000 ? 0 : 1) + 'K';
    return Math.round(n).toLocaleString('ar');
  };
  return `${fmt(convMin)} — ${fmt(convMax)} ${meta.sym}`;
}

async function fetchExchangeRates() {
  // استخدم الكاش إذا لا يزال صالحاً
  if (ratesCache && ratesFetchedAt && (Date.now() - ratesFetchedAt) < RATES_TTL) {
    return ratesCache;
  }
  try {
    // open.er-api.com مجاني بدون مفتاح API
    const res = await fetch('https://open.er-api.com/v6/latest/USD');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    if (data.result !== 'success') throw new Error('bad result');
    // نحتفظ فقط بالعملات التي نحتاجها
    const needed = ['USD','SAR','AED','EGP','IQD','TRY'];
    ratesCache = {};
    needed.forEach(c => { ratesCache[c] = data.rates[c] || FALLBACK_RATES[c]; });
    ratesFetchedAt = Date.now();
    return ratesCache;
  } catch(e) {
    console.warn('fetchExchangeRates failed, using fallback:', e.message);
    return FALLBACK_RATES;
  }
}

// حفظ العملة عند تغييرها من الإعدادات
async function saveCurrency(val) {
  DB.settings.currency = val;
  saveDB();
  const meta = CURRENCY_META[val] || {};
  showToast(`✅ العملة: ${meta.flag||''} ${meta.name||val}`);
  // تحديث شارة السعر في صفحة الإعدادات
  updateCurrencyBadge(val);
  refreshCurrent();
}

async function updateCurrencyBadge(currency) {
  const badge  = document.getElementById('curr-rate-badge');
  const status = document.getElementById('curr-status');
  if (!badge) return;
  badge.textContent = '⏳ ...';
  const rates = await fetchExchangeRates();
  const meta  = CURRENCY_META[currency] || { sym: currency };
  const sarToTarget = convertFromSAR(1, currency); // 1 IQD = ? target
  badge.textContent = `1 ر.س = ${sarToTarget >= 1 ? Math.round(sarToTarget).toLocaleString('ar') : sarToTarget.toFixed(4)} ${meta.sym}`;
  if (status) {
    const isLive = ratesCache && ratesFetchedAt;
    status.textContent = isLive
      ? `✅ سعر مباشر من الإنترنت • آخر تحديث: ${new Date(ratesFetchedAt).toLocaleTimeString('ar')}`
      : '⚠️ سعر احتياطي (تعذّر الاتصال)';
    status.style.color = isLive ? 'var(--g)' : 'var(--yel)';
  }
}

function fmtIQD(n){
  if(n>=1000000) return (n/1000000).toFixed(1)+'M';
  if(n>=1000)    return Math.round(n/1000)+'K';
  return Math.round(n).toLocaleString('ar');
}

function toggleBirdGroup(key){
  const body = document.getElementById('bg-'+key);
  const arrow = document.getElementById('ba-'+key);
  if(!body) return;
  const open = body.style.display !== 'none';
  body.style.display = open ? 'none' : 'block';
  if(arrow) arrow.textContent = open ? '▾' : '▴';
}

async function loadMarketPrices() {
  const container = document.getElementById('market-list-container');
  if (!container) return;

  container.innerHTML = '<div style="text-align:center;padding:14px;font-size:12px;color:var(--txt2)">⏳ جاري جلب أسعار الصرف...</div>';

  const currency = DB.settings.currency || 'IQD';
  await fetchExchangeRates();

  const meta    = CURRENCY_META[currency] || { sym: currency, name: currency, flag: '' };
  const isLive  = ratesCache && ratesFetchedAt;
  const iqdRate = (ratesCache || FALLBACK_RATES)['IQD'] || 1310;
  const toRate  = (ratesCache || FALLBACK_RATES)[currency] || FALLBACK_RATES[currency] || 1;
  const iqdToTarget = toRate / iqdRate;

  let html = `
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;padding:8px 11px;background:var(--bg);border-radius:10px;border:1px solid var(--brd)">
    <div style="font-size:11px;color:var(--txt2)">
      ${meta.flag} <b style="color:var(--txt)">${meta.name}</b>
      &nbsp;•&nbsp; 1000 د.ع = <b style="color:var(--yel)">${(iqdToTarget*1000)>=1 ? (iqdToTarget*1000).toFixed(2) : (iqdToTarget*1000).toFixed(4)} ${meta.sym}</b>
    </div>
    <div style="font-size:10px;color:${isLive?'var(--g)':'var(--yel)'}">
      ${isLive ? '🟢 مباشر' : '🟡 احتياطي'}
    </div>
  </div>
  <div style="display:flex;flex-direction:column;gap:8px">`;

  Object.entries(MARKET_PRICES).forEach(([key, group]) => {
    html += `
    <div style="background:var(--bg);border:1px solid var(--brd);border-radius:12px;overflow:hidden">
      <button onclick="toggleBirdGroup('${key}')" style="width:100%;display:flex;align-items:center;justify-content:space-between;padding:11px 13px;background:none;border:none;cursor:pointer;font-family:var(--font)">
        <div style="display:flex;align-items:center;gap:8px">
          <span style="font-size:20px">${group.emoji}</span>
          <span style="font-size:14px;font-weight:800;color:var(--txt)">${group.label}</span>
          <span style="font-size:10px;color:var(--txt3);background:var(--brd);border-radius:6px;padding:2px 6px">${group.items.length} لون</span>
        </div>
        <span id="ba-${key}" style="color:var(--txt3);font-size:14px">▾</span>
      </button>
      <div id="bg-${key}" style="display:none;padding:0 10px 10px">
        <div style="display:flex;flex-direction:column;gap:5px">
          ${group.items.map(item => {
            const convMin = convertFromSAR(item.min, currency);
            const convMax = convertFromSAR(item.max, currency);
            const fmt = n => {
              if(n>=1000000) return (n/1000000).toFixed(1)+'M';
              if(n>=1000)    return Math.round(n/1000)+'K';
              return Math.round(n).toLocaleString('ar');
            };
            const priceStr = currency==='IQD'
              ? fmtIQD(item.min)+' — '+fmtIQD(item.max)+' د.ع'
              : fmt(convMin)+' — '+fmt(convMax)+' '+meta.sym;
            return `
            <div style="display:flex;align-items:center;justify-content:space-between;background:var(--card);border-radius:9px;padding:8px 10px;border:1px solid var(--brd)">
              <div style="flex:1;min-width:0">
                <div style="font-size:13px;font-weight:700;color:var(--txt)">${item.name}</div>
                ${item.notes?`<div style="font-size:10px;color:var(--txt3);margin-top:1px">${item.notes}</div>`:''}
              </div>
              <div style="font-size:11px;font-weight:800;color:var(--yel);white-space:nowrap;margin-right:8px">${priceStr}</div>
            </div>`;
          }).join('')}
        </div>
      </div>
    </div>`;
  });

  html += `</div>
  <div style="font-size:10px;color:var(--txt3);margin-top:10px;text-align:center">
    🇮🇶 أسعار وحشيات تقريبية من السوق العراقي
  </div>`;

  container.innerHTML = html;
}

// ══════════════════════════════════
// SPLASH SCREEN
// ══════════════════════════════════
(function() {
  const splash = document.getElementById('splash');
  if (!splash) return;
  // إخفاء الشاشة الرئيسية أثناء السبلاش
  const app = document.getElementById('app');
  if (app) app.style.visibility = 'hidden';

  setTimeout(function() {
    splash.classList.add('hide');
    if (app) app.style.visibility = '';
    setTimeout(function() {
      splash.style.display = 'none';
    }, 650);
  }, 3000);
})();

// ══════════════════════════════════
// INIT
// ══════════════════════════════════
loadDB();
renderPage('home');
checkNotifications();
setInterval(checkNotifications, 60000);
document.getElementById('hdr-title').textContent='🦜 '+(DB.settings.farmName||'مزرعة طيوري');
document.getElementById('hdr-btns').innerHTML=(PAGE_HDRS['home']||(() => ''))();
</script>
</body>
</html>

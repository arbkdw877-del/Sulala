// STATE
// ══════════════════════════════════
let DB = {
  birds:[], expenses:[], sales:[], breeding:[], health:[], reminders:[],
  settings:{farmName:'مزرعة طيوري',currency:'IQD'}
};
let currentPage = 'home';
let currentModal = null;
let editingId = null;
let deleteTarget = null;
let confirmCallback = null;

// ── Filters / sort state ──
